# Source control / editor
.git
.gitignore
.gitattributes
.editorconfig
.vscode
.idea

# Build outputs / dependencies — re-installed inside the image
node_modules
dist
coverage
*.tsbuildinfo

# Local env — never bake credentials into the image
.env
.env.*
!.env.example

# Tests + dev tooling not needed at runtime
test
*.spec.ts
.eslintcache
.prettierrc*

# Docs / reference / planning — irrelevant inside the container
README.md
*.md
docs
reference
tasks

# OS noise
.DS_Store
Thumbs.db

# CI artifacts
.github
