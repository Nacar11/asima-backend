### Subscription Plans API Tests
### Base URL
@baseUrl = http://localhost:4080/api/v1

### Login to get token
# @name login
POST {{baseUrl}}/auth/email/login
Content-Type: application/json

{
  "email": "admin@cody.inc",
  "password": "password"
}

### Set token from login response
@token = {{login.response.body.token}}

### ==================================================
### SUBSCRIPTION PLANS ENDPOINTS
### ==================================================

### Create Subscription Plan
# @name createPlan
POST {{baseUrl}}/subscription-plans
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "plan_name": "Basic Plan",
  "plan_code": "BASIC",
  "description": "Basic subscription plan for small businesses",
  "plan_type": "unified",
  "price": 499.00,
  "billing_cycle": "monthly",
  "features": ["Up to 100 products", "Up to 10 services", "Email support"],
  "max_sellers": 1,
  "max_products": 100,
  "max_services": 10,
  "max_members": 3,
  "commission_percent": 10.00,
  "display_order": 1,
  "status": "active"
}

### Create Premium Plan
# @name createPremiumPlan
POST {{baseUrl}}/subscription-plans
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "plan_name": "Premium Plan",
  "plan_code": "PREMIUM",
  "description": "Premium subscription plan for growing businesses",
  "plan_type": "unified",
  "price": 1499.00,
  "billing_cycle": "monthly",
  "features": ["Unlimited products", "Unlimited services", "Priority support", "Custom branding"],
  "max_sellers": 5,
  "commission_percent": 5.00,
  "display_order": 2,
  "status": "active"
}

### Get All Subscription Plans (with pagination)
GET {{baseUrl}}/subscription-plans?page=1&limit=10
Authorization: Bearer {{token}}

### Get Active Subscription Plans
GET {{baseUrl}}/subscription-plans/active
Authorization: Bearer {{token}}

### Get Subscription Plans Lookup
GET {{baseUrl}}/subscription-plans/lookup?take=10
Authorization: Bearer {{token}}

### Get Subscription Plan by ID
@planId = {{createPlan.response.body.id}}
GET {{baseUrl}}/subscription-plans/{{planId}}
Authorization: Bearer {{token}}

### Update Subscription Plan
PATCH {{baseUrl}}/subscription-plans/{{planId}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "description": "Updated basic subscription plan",
  "price": 599.00
}

### Delete Subscription Plan
DELETE {{baseUrl}}/subscription-plans/{{planId}}
Authorization: Bearer {{token}}



