  "reason": "Schedule conflict - not available on requested date",
  "notes": "Please try rebooking for next week"
}

### Update Provider Notes
# @name updateProviderNotes
PATCH {{baseUrl}}/api/v1/bookings/1/notes
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "provider_notes": "Customer prefers morning appointments. Bring extra supplies."
}

