### Variables
@baseUrl = http://localhost:4080
@adminEmail = admin@cody.inc
@adminPassword = password

### Get Auth Token
# @name login
POST {{baseUrl}}/api/v1/auth/email/login
accept: application/json
Content-Type: application/json

{
  "email": "{{adminEmail}}",
  "password": "{{adminPassword}}"
}

###
### ===========================================
### GET BOOKING ENDPOINTS
### ===========================================

### Get My Bookings (as Customer)
# @name getMyBookings
GET {{baseUrl}}/api/v1/bookings/my-bookings?page=1&limit=20
Authorization: Bearer {{login.response.body.token}}

### Get My Bookings with Status Filter
# @name getMyBookingsPending
GET {{baseUrl}}/api/v1/bookings/my-bookings?page=1&limit=20&status=pending
Authorization: Bearer {{login.response.body.token}}

### Get My Seller Bookings (Current User's Seller Account)
# @name getMySellerBookings
GET {{baseUrl}}/api/v1/bookings/seller-bookings?page=1&limit=20
Authorization: Bearer {{login.response.body.token}}

### Get My Seller Bookings with Status Filter
# @name getMySellerBookingsPending
GET {{baseUrl}}/api/v1/bookings/seller-bookings?page=1&limit=20&status=pending
Authorization: Bearer {{login.response.body.token}}

### Get Seller Bookings
# @name getSellerBookings
GET {{baseUrl}}/api/v1/bookings/seller/1?page=1&limit=20
Authorization: Bearer {{login.response.body.token}}

### Get Bookings by Checkout Order
# @name getBookingsByCheckoutOrder
GET {{baseUrl}}/api/v1/bookings/checkout-order/1
Authorization: Bearer {{login.response.body.token}}

### Get Booking by ID
# @name getBookingById
GET {{baseUrl}}/api/v1/bookings/1
Authorization: Bearer {{login.response.body.token}}

### Get All Bookings (Admin)
# @name getAllBookings
GET {{baseUrl}}/api/v1/bookings?page=1&limit=20
Authorization: Bearer {{login.response.body.token}}

###
### ===========================================
### PREVENTIVE BOOKING REQUEST (Phase 4 - MEPF Flow)
### ===========================================

### Request Quote - Single Booking (Preventive Flow)
# Creates a booking with status AWAITING_QUOTATION for a service that requires a quote.
# No payment is required at this stage.
# @name requestQuoteSingle
POST {{baseUrl}}/api/v1/bookings/request-quote
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "service_id": 1,
  "form_values": [
    {
      "form_template_id": 1,
      "field_code": "quantity",
      "value": "10"
    },
    {
      "form_template_id": 2,
      "field_code": "size",
      "value": "large"
    }
  ],
  "is_recurring": false,
  "scheduled_date": "2026-02-15",
  "scheduled_start_time": "10:00:00",
  "service_address_id": 1,
  "customer_notes": "Need quotation for large quantity order"
}

### Request Quote - Recurring Booking (Monthly for 6 months)
# Creates multiple bookings linked by recurrence_group_id
# @name requestQuoteRecurring
POST {{baseUrl}}/api/v1/bookings/request-quote
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "service_id": 1,
  "form_values": [
    {
      "form_template_id": 1,
      "field_code": "quantity",
      "value": "5"
    }
  ],
  "is_recurring": true,
  "recurrence_count": 6,
  "recurrence_interval": "monthly",
  "scheduled_date": "2026-02-01",
  "scheduled_start_time": "09:00:00",
  "service_address_id": 1,
  "customer_notes": "Monthly preventive maintenance service"
}

### Request Quote - Error: Service doesn't require quote
# Should fail with 400 error if service.requires_quote = false
# @name requestQuoteErrorNotRequiresQuote
POST {{baseUrl}}/api/v1/bookings/request-quote
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "service_id": 2,
  "form_values": [],
  "is_recurring": false,
  "scheduled_date": "2026-02-15",
  "service_address_id": 1
}

###
### ===========================================
### CALENDAR ENDPOINTS
### ===========================================

### Get Seller Calendar (Month View)
# @name getSellerCalendar
GET {{baseUrl}}/api/v1/bookings/sellers/1/calendar?month=2024-12
Authorization: Bearer {{login.response.body.token}}

### Get Seller Day Schedule
# @name getSellerDaySchedule
GET {{baseUrl}}/api/v1/bookings/sellers/1/schedule?date=2024-12-25
Authorization: Bearer {{login.response.body.token}}

###
### ===========================================
### ADMIN BOOKING ENDPOINTS
### ===========================================

### Get All Bookings (Admin)
# @name adminGetAllBookings
GET {{baseUrl}}/api/v1/bookings?page=1&limit=20
Authorization: Bearer {{login.response.body.token}}

### Get Booking by ID (Admin - bypasses access check)
# @name adminGetBookingById
GET {{baseUrl}}/api/v1/bookings/admin/1
Authorization: Bearer {{login.response.body.token}}

### Admin Force Cancel Booking
# @name adminForceCancel
POST {{baseUrl}}/api/v1/bookings/admin/1/force-cancel
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "reason": "other",
  "reason_details": "Admin cancellation due to policy violation",
  "refund_percent": 100,
  "notify_parties": true
}

### Admin Force Complete Booking
# @name adminForceComplete
POST {{baseUrl}}/api/v1/bookings/admin/1/force-complete
Authorization: Bearer {{login.response.body.token}}

### Admin Initiate Refund
# @name adminRefund
POST {{baseUrl}}/api/v1/bookings/admin/1/refund
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "amount": 1000.0,
  "reason": "Admin-initiated refund due to service issue",
  "notify_customer": true
}

###
### ===========================================
### POST BOOKING ENDPOINTS (CREATE)
### ===========================================

### Create Booking from Checkout Order
# @name createBooking
POST {{baseUrl}}/api/v1/bookings
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "checkout_order_id": 1,
  "seller_id": 1,
  "service_id": 1,
  "customer_id": 1,
  "scheduled_date": "2024-12-25",
  "scheduled_start_time": "09:00:00",
  "scheduled_end_time": "11:00:00",
  "subtotal": 1500.00,
  "customer_notes": "Please arrive before 9 AM"
}

### Create Booking with Package
# @name createBookingWithPackage
POST {{baseUrl}}/api/v1/bookings
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "checkout_order_id": 1,
  "seller_id": 1,
  "service_id": 1,
  "package_id": 1,
  "customer_id": 1,
  "scheduled_date": "2024-12-25",
  "scheduled_start_time": "09:00:00",
  "scheduled_end_time": "11:00:00",
  "service_address_id": 1,
  "subtotal": 2000.00,
  "platform_fee_percent": 10.0
}

### Create Booking with Custom Address
# @name createBookingCustomAddress
POST {{baseUrl}}/api/v1/bookings
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "checkout_order_id": 1,
  "seller_id": 1,
  "service_id": 1,
  "customer_id": 1,
  "scheduled_date": "2024-12-25",
  "scheduled_start_time": "09:00:00",
  "service_address_text": "123 Main St, City, Province",
  "service_latitude": 14.5995,
  "service_longitude": 120.9842,
  "subtotal": 1500.00
}

###
### ===========================================
### PATCH BOOKING ENDPOINTS (UPDATE)
### ===========================================

### Update Booking
# @name updateBooking
PATCH {{baseUrl}}/api/v1/bookings/{{createBooking.response.body.id}}
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "scheduled_date": "2024-12-26",
  "scheduled_start_time": "10:00:00",
  "customer_notes": "Updated notes"
}

### Assign Member to Booking
# @name assignMember
PATCH {{baseUrl}}/api/v1/bookings/{{createBooking.response.body.id}}/assign-member
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "assigned_member_id": 1
}

### Confirm Booking
# @name confirmBooking
PATCH {{baseUrl}}/api/v1/bookings/{{createBooking.response.body.id}}/confirm
Authorization: Bearer {{login.response.body.token}}

### Start Service
# @name startService
PATCH {{baseUrl}}/api/v1/bookings/{{createBooking.response.body.id}}/start
Authorization: Bearer {{login.response.body.token}}

### Complete Service
# @name completeService
PATCH {{baseUrl}}/api/v1/bookings/{{createBooking.response.body.id}}/complete
Authorization: Bearer {{login.response.body.token}}

### Cancel Booking
# @name cancelBooking
PATCH {{baseUrl}}/api/v1/bookings/{{createBooking.response.body.id}}/cancel
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "status": "cancelled",
  "notes": "Customer requested cancellation"
}

### Update Booking Status
# @name updateBookingStatus
PATCH {{baseUrl}}/api/v1/bookings/{{createBooking.response.body.id}}/status
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "status": "confirmed",
  "notes": "Booking confirmed by seller"
}

###
### ===========================================
### ERROR TESTING
### ===========================================

### Create Booking with Invalid Checkout Order (Should Fail)
# @name createBookingInvalidCheckout
POST {{baseUrl}}/api/v1/bookings
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "checkout_order_id": 99999,
  "seller_id": 1,
  "service_id": 1,
  "customer_id": 1,
  "scheduled_date": "2024-12-25",
  "scheduled_start_time": "09:00:00",
  "subtotal": 1500.00
}

### Get Non-Existent Booking (Should Return 404)
# @name getNonExistentBooking
GET {{baseUrl}}/api/v1/bookings/99999
Authorization: Bearer {{login.response.body.token}}

### Update Non-Existent Booking (Should Return 404)
# @name updateNonExistentBooking
PATCH {{baseUrl}}/api/v1/bookings/99999
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "status": "confirmed"
}

### Create Booking Without Auth (Should Return 401)
# @name createBookingUnauthorized
POST {{baseUrl}}/api/v1/bookings
Content-Type: application/json

{
  "checkout_order_id": 1,
  "seller_id": 1,
  "service_id": 1,
  "customer_id": 1,
  "scheduled_date": "2024-12-25",
  "scheduled_start_time": "09:00:00",
  "subtotal": 1500.00
}

### Update with Invalid Status (Should Return 422)
# @name updateInvalidStatus
PATCH {{baseUrl}}/api/v1/bookings/{{createBooking.response.body.id}}/status
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "status": "invalid_status"
}

### Start Service with Invalid Status (Should Return 400)
# @name startServiceInvalidStatus
PATCH {{baseUrl}}/api/v1/bookings/{{createBooking.response.body.id}}/start
Authorization: Bearer {{login.response.body.token}}

