# @name login
POST {{baseUrl}}/api/v1/auth/email/login
accept: application/json
Content-Type: application/json

{
  "email": "{{adminEmail}}",
  "password": "{{adminPassword}}"
}

###
# @name createSeller
POST {{baseUrl}}/api/v1/sellers
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "user_id": 1,
  "store_name": "Service Store {{timestamp}}",
  "slug": "service-store-{{timestamp}}",
  "sells_products": true,
  "sells_services": true,
  "business_type": "sole_proprietor",
  "bio": "New unified marketplace seller",
  "years_of_experience": 5,
  "hourly_rate": 20.5,
  "auto_accept_bookings": true
}

###
# @name listSellers
GET {{baseUrl}}/api/v1/sellers?take=10&skip=0
Authorization: Bearer {{login.response.body.token}}

###
# @name getSeller
GET {{baseUrl}}/api/v1/sellers/{{createSeller.response.body.id}}
Authorization: Bearer {{login.response.body.token}}

###
# @name getSellerProfile
# Get public profile of a seller/service provider
GET {{baseUrl}}/api/v1/sellers/1/profile
Authorization: Bearer {{login.response.body.token}}

###
# @name getSellerServices
# Get services offered by a seller
GET {{baseUrl}}/api/v1/sellers/1/services?skip=0&take=10
Authorization: Bearer {{login.response.body.token}}

###
# @name getSellerServicesWithFilters
# Get services offered by a seller with filters
GET {{baseUrl}}/api/v1/sellers/1/services?skip=0&take=10&status=active&search=plumbing
Authorization: Bearer {{login.response.body.token}}

###
# @name getSellerPortfolio
# Get portfolio items of a seller
GET {{baseUrl}}/api/v1/sellers/1/portfolio
Authorization: Bearer {{login.response.body.token}}

###
# @name getSellerReviews
# Get reviews for a seller
GET {{baseUrl}}/api/v1/sellers/1/reviews?skip=0&take=20
Authorization: Bearer {{login.response.body.token}}

###
# @name getSellerReviewsWithMinRating
# Get reviews for a seller with minimum rating filter
GET {{baseUrl}}/api/v1/sellers/1/reviews?skip=0&take=20&min_rating=4
Authorization: Bearer {{login.response.body.token}}

###
# @name updateSeller
PATCH {{baseUrl}}/api/v1/sellers/{{createSeller.response.body.id}}
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "bio": "Updated bio",
  "sells_services": true,
  "auto_accept_bookings": false
}

###
# @name deleteSeller
DELETE {{baseUrl}}/api/v1/sellers/{{createSeller.response.body.id}}
Authorization: Bearer {{login.response.body.token}}

###
### ===========================================
### EARNINGS ENDPOINTS (TRV-027)
### ===========================================

# @name getMyEarningsSummary
# Get my earnings summary (convenience endpoint for mobile)
GET {{baseUrl}}/api/v1/sellers/me/earnings/summary
Authorization: Bearer {{login.response.body.token}}

###
# @name getMyEarningsHistory
# Get my earnings history with pagination (TRV-027)
GET {{baseUrl}}/api/v1/sellers/me/earnings/history?page=1&limit=20
Authorization: Bearer {{login.response.body.token}}

###
# @name getMyEarningsHistoryFiltered
# Get my earnings history filtered by status
GET {{baseUrl}}/api/v1/sellers/me/earnings/history?page=1&limit=20&status=available
Authorization: Bearer {{login.response.body.token}}
