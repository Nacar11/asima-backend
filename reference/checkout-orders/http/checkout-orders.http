### Variables
@baseUrl = http://localhost:4080
@adminEmail = admin@cody.inc
@adminPassword = password

### Get Auth Token
# @name login
POST {{baseUrl}}/api/v1/auth/email/login
accept: application/json
Content-Type: application/json

{
  "email": "{{adminEmail}}",
  "password": "{{adminPassword}}"
}

###
### ===========================================
### GET CHECKOUT ORDER ENDPOINTS
### ===========================================

### Get My Checkout Orders
# @name getMyOrders
GET {{baseUrl}}/api/v1/checkout-orders/my-orders?page=1&limit=20
Authorization: Bearer {{login.response.body.token}}

### Get My Checkout Orders with Status Filter
# @name getMyOrdersPending
GET {{baseUrl}}/api/v1/checkout-orders/my-orders?page=1&limit=20&status=pending
Authorization: Bearer {{login.response.body.token}}

### Get My Checkout Orders with Payment Status Filter
# @name getMyOrdersPaid
GET {{baseUrl}}/api/v1/checkout-orders/my-orders?page=1&limit=20&payment_status=paid
Authorization: Bearer {{login.response.body.token}}

### Get Checkout Order by ID
# @name getCheckoutOrderById
GET {{baseUrl}}/api/v1/checkout-orders/1
Authorization: Bearer {{login.response.body.token}}

### Get All Checkout Orders (Admin)
# @name getAllOrders
GET {{baseUrl}}/api/v1/checkout-orders?page=1&limit=20
Authorization: Bearer {{login.response.body.token}}

###
### ===========================================
### POST CHECKOUT ORDER ENDPOINTS (CREATE)
### ===========================================

### Create Checkout Order from Cart (Minimal)
# @name createCheckoutOrder
POST {{baseUrl}}/api/v1/checkout-orders
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "customer_notes": "Please handle with care"
}

### Create Checkout Order from Cart (With Addresses)
# @name createCheckoutOrderWithAddresses
POST {{baseUrl}}/api/v1/checkout-orders
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "delivery_address_id": 1,
  "service_address_id": 2,
  "customer_notes": "Please leave at the front door",
  "source": "mobile_app"
}

### Create Checkout Order from Cart (With Service Address Only)
# @name createCheckoutOrderServiceOnly
POST {{baseUrl}}/api/v1/checkout-orders
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "service_address_id": 1,
  "customer_notes": "Service appointment"
}

###
### ===========================================
### PATCH CHECKOUT ORDER ENDPOINTS (UPDATE)
### ===========================================

### Update Checkout Order Status
# @name updateCheckoutOrderStatus
PATCH {{baseUrl}}/api/v1/checkout-orders/{{createCheckoutOrder.response.body.id}}
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "status": "confirmed"
}

### Update Payment Status
# @name updatePaymentStatus
PATCH {{baseUrl}}/api/v1/checkout-orders/{{createCheckoutOrder.response.body.id}}
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "payment_status": "paid"
}

### Update Checkout Order with Multiple Fields
# @name updateCheckoutOrderMultiple
PATCH {{baseUrl}}/api/v1/checkout-orders/{{createCheckoutOrder.response.body.id}}
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "status": "processing",
  "payment_status": "paid",
  "customer_notes": "Updated notes",
  "internal_notes": "VIP customer"
}

### Cancel Checkout Order
# @name cancelCheckoutOrder
PATCH {{baseUrl}}/api/v1/checkout-orders/{{createCheckoutOrder.response.body.id}}
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "status": "cancelled",
  "cancellation_reason": "Customer requested cancellation"
}

### Update Delivery Address
# @name updateDeliveryAddress
PATCH {{baseUrl}}/api/v1/checkout-orders/{{createCheckoutOrder.response.body.id}}
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "delivery_address_id": 2
}

### Update Service Address
# @name updateServiceAddress
PATCH {{baseUrl}}/api/v1/checkout-orders/{{createCheckoutOrder.response.body.id}}
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "service_address_id": 3
}

###
### ===========================================
### ERROR TESTING
### ===========================================

### Create Checkout Order with Empty Cart (Should Fail)
# @name createCheckoutOrderEmptyCart
POST {{baseUrl}}/api/v1/checkout-orders
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{}

### Get Non-Existent Checkout Order (Should Return 404)
# @name getNonExistentOrder
GET {{baseUrl}}/api/v1/checkout-orders/99999
Authorization: Bearer {{login.response.body.token}}

### Update Non-Existent Checkout Order (Should Return 404)
# @name updateNonExistentOrder
PATCH {{baseUrl}}/api/v1/checkout-orders/99999
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "status": "confirmed"
}

### Create Checkout Order Without Auth (Should Return 401)
# @name createCheckoutOrderUnauthorized
POST {{baseUrl}}/api/v1/checkout-orders
Content-Type: application/json

{
  "customer_notes": "Test"
}

### Update with Invalid Status (Should Return 422)
# @name updateInvalidStatus
PATCH {{baseUrl}}/api/v1/checkout-orders/{{createCheckoutOrder.response.body.id}}
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "status": "invalid_status"
}

### Update with Invalid Payment Status (Should Return 422)
# @name updateInvalidPaymentStatus
PATCH {{baseUrl}}/api/v1/checkout-orders/{{createCheckoutOrder.response.body.id}}
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "payment_status": "invalid_payment_status"
}

###
### ===========================================
### ORDER ACTIONS (TRV-015)
### ===========================================

### Confirm Checkout Order
# @name confirmCheckoutOrder
POST {{baseUrl}}/api/v1/checkout-orders/1/confirm
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "payment_method": "gcash",
  "notes": "Confirming my order"
}

### Confirm Checkout Order (Minimal)
# @name confirmCheckoutOrderMinimal
POST {{baseUrl}}/api/v1/checkout-orders/1/confirm
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{}

### Cancel Checkout Order
# @name cancelCheckoutOrderAction
POST {{baseUrl}}/api/v1/checkout-orders/1/cancel
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "cancellation_reason": "Changed my mind",
  "cancellation_details": "Found a better deal elsewhere"
}

### Cancel Checkout Order (Required Fields Only)
# @name cancelCheckoutOrderMinimal
POST {{baseUrl}}/api/v1/checkout-orders/1/cancel
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "cancellation_reason": "No longer needed"
}
