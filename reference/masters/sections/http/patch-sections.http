### Get Auth Token
# @name login
POST {{BACKEND_DOMAIN}}/api/v1/auth/email/login
Content-Type: application/json

{
  "email": "{{TEST_EMAIL}}",
  "password": "{{TEST_PASSWORD}}"
}

### Set token variable from login response
@token = {{login.token}}

### ===========================================
### PATCH SECTIONS ENDPOINTS (UPDATE)
### ===========================================

### Update Section (Basic Fields)
PATCH {{BACKEND_DOMAIN}}/api/v1/sections/1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "section_name": "Updated Development Section",
  "remarks": "Updated remarks for development section"
}

### Update Section (Status Change)
PATCH {{BACKEND_DOMAIN}}/api/v1/sections/1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "status": "Active"
}

### Update Section (Complete Update)
PATCH {{BACKEND_DOMAIN}}/api/v1/sections/1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "division": "01",
  "section_code": "01",
  "section_name": "Advanced Development Section",
  "remarks": "Updated development section with enhanced capabilities",
  "status": "Active"
}

### Update Section (Multiple Fields)
PATCH {{BACKEND_DOMAIN}}/api/v1/sections/1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "section_name": "Strategic Development Section",
  "remarks": "Updated strategic development section"
}
