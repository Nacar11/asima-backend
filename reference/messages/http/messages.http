# @name login
POST {{baseUrl}}/api/v1/auth/email/login
accept: application/json
Content-Type: application/json

{
  "email": "{{adminEmail}}",
  "password": "{{adminPassword}}"
}

###
# @name createConversation
POST {{baseUrl}}/api/v1/messages/conversations
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "seller_id": 1,
  "customer_id": 2,
  "context_type": "general"
}

###
# @name createConversationWithBooking
POST {{baseUrl}}/api/v1/messages/conversations
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "seller_id": 1,
  "customer_id": 2,
  "context_type": "booking",
  "context_id": 1
}

###
# @name getConversations
GET {{baseUrl}}/api/v1/messages/conversations?page=1&limit=20
Authorization: Bearer {{login.response.body.token}}

###
# @name getConversationsWithStatus
GET {{baseUrl}}/api/v1/messages/conversations?page=1&limit=20&status=active
Authorization: Bearer {{login.response.body.token}}

###
# @name getConversation
GET {{baseUrl}}/api/v1/messages/conversations/{{createConversation.response.body.id}}
Authorization: Bearer {{login.response.body.token}}

###
# @name sendTextMessage
POST {{baseUrl}}/api/v1/messages/messages
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "conversation_id": {{createConversation.response.body.id}},
  "message_type": "text",
  "content": "Hello, I have a question about your service."
}

###
# @name sendImageMessage
POST {{baseUrl}}/api/v1/messages/messages
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "conversation_id": {{createConversation.response.body.id}},
  "message_type": "image",
  "attachments": [
    {
      "file_url": "https://example.com/images/photo.jpg",
      "file_name": "photo.jpg",
      "mime_type": "image/jpeg",
      "file_size": 1024000,
      "caption": "Photo of completed work"
    }
  ]
}

###
# @name sendFileMessage
POST {{baseUrl}}/api/v1/messages/messages
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "conversation_id": {{createConversation.response.body.id}},
  "message_type": "file",
  "attachments": [
    {
      "file_url": "https://example.com/files/document.pdf",
      "file_name": "document.pdf",
      "mime_type": "application/pdf",
      "file_size": 2048000
    }
  ]
}

###
# @name getMessages
GET {{baseUrl}}/api/v1/messages/conversations/{{createConversation.response.body.id}}/messages?page=1&limit=50
Authorization: Bearer {{login.response.body.token}}

###
# @name markAllAsRead
POST {{baseUrl}}/api/v1/messages/conversations/{{createConversation.response.body.id}}/read
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{}

###
# @name markSpecificMessagesAsRead
POST {{baseUrl}}/api/v1/messages/conversations/{{createConversation.response.body.id}}/read
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "message_ids": [1, 2, 3]
}

###
# @name archiveConversation
POST {{baseUrl}}/api/v1/messages/conversations/{{createConversation.response.body.id}}/archive
Authorization: Bearer {{login.response.body.token}}

