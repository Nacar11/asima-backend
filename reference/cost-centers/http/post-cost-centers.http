### Get Auth Token
# @name login
POST {{BACKEND_DOMAIN}}/api/v1/auth/email/login
Content-Type: application/json

{
  "email": "{{TEST_EMAIL}}",
  "password": "{{TEST_PASSWORD}}"
}

### Set token variable from login response
@token = {{login.token}}

### ===========================================
### POST COST CENTERS ENDPOINTS (CREATE)
### ===========================================

### Create Cost Center (Minimal - Division Only)
POST {{BACKEND_DOMAIN}}/api/v1/cost-centers
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "division": "00",
  "remarks": "Test Cost Center - Division Only"
}

### Create Cost Center (With Department)
POST {{BACKEND_DOMAIN}}/api/v1/cost-centers
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "division": "00",
  "department": "01",
  "remarks": "Test Cost Center - Division and Department"
}

### Create Cost Center (With Section)
POST {{BACKEND_DOMAIN}}/api/v1/cost-centers
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "division": "00",
  "department": "01",
  "section": "02",
  "remarks": "Test Cost Center - Division, Department, and Section"
}

### Create Cost Center (Complete Hierarchy)
POST {{BACKEND_DOMAIN}}/api/v1/cost-centers
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "division": "00",
  "department": "03",
  "section": "09",
  "sub_section": "02",
  "remarks": "Test Cost Center - Complete Hierarchy",
  "status": "Active"
}

### Create Cost Center (With Hold Status)
POST {{BACKEND_DOMAIN}}/api/v1/cost-centers
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "division": "01",
  "department": "01",
  "section": "01",
  "sub_section": "01",
  "remarks": "Test Cost Center - Hold Status",
  "status": "Hold"
}

### Create Cost Center (With Cancelled Status)
POST {{BACKEND_DOMAIN}}/api/v1/cost-centers
