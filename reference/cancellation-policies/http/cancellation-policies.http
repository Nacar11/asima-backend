### Variables
@baseUrl = http://localhost:3000/api/v1
@token = {{$dotenv AUTH_TOKEN}}

### ===========================================
### AUTHENTICATION
### ===========================================

### Authenticate (run first to get token)
# @name auth
POST {{baseUrl}}/auth/email/login
Content-Type: application/json

{
  "email": "admin@cody.inc",
  "password": "password"
}

### Set token from auth response
@token = {{auth.response.body.token}}

### ===========================================
### CANCELLATION POLICIES CRUD
### ===========================================

### Get all cancellation policies
GET {{baseUrl}}/cancellation-policies
Authorization: Bearer {{token}}

### Get all with filters
GET {{baseUrl}}/cancellation-policies?status=Active&page=1&limit=10
Authorization: Bearer {{token}}

### Get default platform policy
GET {{baseUrl}}/cancellation-policies/default
Authorization: Bearer {{token}}

### Get cancellation policies for seller
GET {{baseUrl}}/cancellation-policies/sellers/1
Authorization: Bearer {{token}}

### Get cancellation policy for service
GET {{baseUrl}}/cancellation-policies/services/1
Authorization: Bearer {{token}}

### Get applicable policy (with fallback)
GET {{baseUrl}}/cancellation-policies/applicable?service_id=1&seller_id=1
Authorization: Bearer {{token}}

### Get cancellation policy by ID
GET {{baseUrl}}/cancellation-policies/1
Authorization: Bearer {{token}}

### Create platform default cancellation policy
POST {{baseUrl}}/cancellation-policies
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Platform Default Policy",
  "description": "Default cancellation policy for all services",
  "free_cancel_hours": 48,
  "partial_cancel_hours": 24,
  "partial_cancel_percent": 50,
  "no_show_charge_percent": 100
}

### Create seller-specific cancellation policy
POST {{baseUrl}}/cancellation-policies
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "seller_id": 1,
  "name": "Flexible Seller Policy",
  "description": "Customer-friendly cancellation policy for this seller",
  "free_cancel_hours": 72,
  "partial_cancel_hours": 48,
  "partial_cancel_percent": 75,
  "no_show_charge_percent": 100
}

### Create service-specific cancellation policy
POST {{baseUrl}}/cancellation-policies
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "seller_id": 1,
  "service_id": 1,
  "name": "Premium Service Policy",
  "description": "Strict policy for premium services",
  "free_cancel_hours": 24,
  "partial_cancel_hours": 12,
  "partial_cancel_percent": 25,
  "no_show_charge_percent": 100
}

### Update cancellation policy
PATCH {{baseUrl}}/cancellation-policies/1
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Updated Policy Name",
  "partial_cancel_percent": 60
}

### Delete cancellation policy (soft delete)
DELETE {{baseUrl}}/cancellation-policies/1
Authorization: Bearer {{token}}

