### Get all service addons
GET {{baseUrl}}/v1/service-addons
Authorization: Bearer {{authToken}}

### Get addons for a specific service
GET {{baseUrl}}/v1/service-addons/by-service/1
Authorization: Bearer {{authToken}}

### Get addon by ID
GET {{baseUrl}}/v1/service-addons/1
Authorization: Bearer {{authToken}}

### Create a new addon
POST {{baseUrl}}/v1/service-addons
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "service_id": 1,
  "name": "Disinfectant Spraying",
  "code": "DISINFECTANT_SPRAY",
  "description": "Complete disinfection of all surfaces",
  "short_description": "Surface disinfection",
  "unit_type": "per order",
  "price": 328.00,
  "compare_at_price": 400.00,
  "duration_minutes": 30,
  "min_quantity": 0,
  "max_quantity": 5,
  "display_order": 1,
  "is_popular": true,
  "is_required": false,
  "status": "active",
  "inclusions": [
    { "description": "Hospital-grade disinfectant", "display_order": 0 },
    { "description": "All high-touch surfaces", "display_order": 1 },
    { "description": "Air purification spray", "display_order": 2 }
  ]
}

### Update an addon
PATCH {{baseUrl}}/v1/service-addons/1
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "price": 350.00,
  "inclusions": [
    { "id": 1, "description": "Hospital-grade disinfectant (updated)", "display_order": 0 },
    { "description": "New inclusion item", "display_order": 3 }
  ]
}

### Delete an addon
DELETE {{baseUrl}}/v1/service-addons/1
Authorization: Bearer {{authToken}}

### Bulk delete addons
DELETE {{baseUrl}}/v1/service-addons/bulk
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "ids": [1, 2, 3]
}

