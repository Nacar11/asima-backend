# @name login
POST {{baseUrl}}/api/v1/auth/email/login
accept: application/json
Content-Type: application/json

{
  "email": "{{adminEmail}}",
  "password": "{{adminPassword}}"
}

###
# @name createServiceCategory
POST {{baseUrl}}/api/v1/service-categories
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "name": "Cleaning {{timestamp}}",
  "code": "cleaning-{{timestamp}}",
  "description": "Cleaning services",
  "is_active": true,
  "is_featured": false,
  "default_platform_fee_percent": 10
}

###
# @name listServiceCategories
GET {{baseUrl}}/api/v1/service-categories?take=10&skip=0
Authorization: Bearer {{login.response.body.token}}

###
# @name listServiceCategoriesSortedByName
GET {{baseUrl}}/api/v1/service-categories?take=10&skip=0&sortField=name&sortBy=ASC
Authorization: Bearer {{login.response.body.token}}

###
# @name listServiceCategoriesSortedByCreatedAt
GET {{baseUrl}}/api/v1/service-categories?take=10&skip=0&sortField=created_at&sortBy=DESC
Authorization: Bearer {{login.response.body.token}}

###
# @name getServiceCategory
GET {{baseUrl}}/api/v1/service-categories/{{createServiceCategory.response.body.id}}
Authorization: Bearer {{login.response.body.token}}

###
# @name updateServiceCategory
PATCH {{baseUrl}}/api/v1/service-categories/{{createServiceCategory.response.body.id}}
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "description": "Updated description",
  "is_featured": true
}

###
# @name deleteServiceCategory
DELETE {{baseUrl}}/api/v1/service-categories/{{createServiceCategory.response.body.id}}
Authorization: Bearer {{login.response.body.token}}

