<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}} - {{app_name}}</title>
  <!--[if mso]>
  <style type="text/css">
    table { border-collapse: collapse; }
    .wrapper { width: 100% !important; }
    .container { width: 480px !important; }
  </style>
  <![endif]-->
</head>
<body style="margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; line-height: 1.5; color: #1a1a1a; background-color: #f5f5f5; -webkit-font-smoothing: antialiased;">
  <!-- Wrapper -->
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #f5f5f5;">
    <tr>
      <td align="center" style="padding: 40px 20px;">
        <!-- Container -->
        <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="max-width: 480px; background-color: #ffffff; border-radius: 12px; overflow: hidden;">

          <!-- Logo -->
          {{#if logo_url}}
          <tr>
            <td align="center" style="padding: 30px 30px 0;">
              <img src="{{logo_url}}" alt="{{app_name}}" width="150" style="display: block; max-width: 150px; height: auto;">
            </td>
          </tr>
          {{/if}}

          <!-- Header with Icon -->
          <tr>
            <td align="center" style="padding: 30px 30px 30px; border-bottom: 1px solid #f0f0f0;">
              <!-- Icon Circle -->
              <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td align="center" style="width: 64px; height: 64px; background-color: #e0f2fe; border-radius: 50%;">
                    <img src="https://img.icons8.com/ios-filled/50/3b82f6/checkmark--v1.png" alt="Verify" width="32" height="32" style="display: block;">
                  </td>
                </tr>
              </table>
              <h1 style="margin: 20px 0 8px; font-size: 24px; font-weight: 600; color: #1a1a1a;">{{title}}</h1>
              <p style="margin: 0; color: #666666; font-size: 15px;">Welcome to {{app_name}}</p>
            </td>
          </tr>

          <!-- Content -->
          <tr>
            <td style="padding: 30px;">
              <!-- Greeting -->
              <p style="margin: 0 0 20px; color: #666666; font-size: 15px; line-height: 1.6;">
                {{text1}}
              </p>
              <p style="margin: 0 0 20px; color: #666666; font-size: 15px; line-height: 1.6;">
                {{text2}} {{app_name}}. Copy and paste the verification code below into the app to complete your registration.
              </p>

              <!-- OTP Code Section -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 20px;">
                <tr>
                  <td align="center" style="padding: 24px; background-color: #f5f5f5; border-radius: 8px;">
                    <p style="margin: 0 0 12px; font-size: 13px; color: #666666; text-transform: uppercase; letter-spacing: 0.5px;">Your verification code</p>
                    <p style="margin: 0; font-size: 36px; font-weight: 700; color: #3b82f6; letter-spacing: 8px; font-family: 'Courier New', monospace;">{{otp}}</p>
                    <p style="margin: 12px 0 0; font-size: 13px; color: #999999;">Valid for 15 minutes</p>
                  </td>
                </tr>
              </table>

              <!-- Divider -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin: 20px 0;">
                <tr>
                  <td style="padding: 0 20px;">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td width="50%" style="border-top: 1px solid #e0e0e0;"></td>
                        <td style="padding: 0 15px; white-space: nowrap; color: #999999; font-size: 13px; text-align: center;">or</td>
                        <td width="50%" style="border-top: 1px solid #e0e0e0;"></td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>

              <!-- CTA Button -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin: 20px 0;">
                <tr>
                  <td align="center">
                    <a href="{{url}}" style="display: inline-block; padding: 14px 32px; background-color: #3b82f6; border-radius: 8px; color: #ffffff; text-decoration: none; font-size: 14px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px;">{{actionTitle}}</a>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td align="center" style="padding: 20px 30px; background-color: #fafafa; border-top: 1px solid #f0f0f0;">
              <p style="margin: 0 0 8px; font-size: 12px; color: #999999;">Best regards, The {{app_name}} Team</p>
              <p style="margin: 0; font-size: 12px; color: #999999;">This is an automated message. Please do not reply.</p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
