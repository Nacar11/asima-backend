<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="x-ua-compatible" content="ie=edge" />
    <title>Booking Awaiting Payment Confirmation</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
  </head>
  <body style="margin: 0; padding: 0; background-color: #f5f5f5; font-family: Arial, sans-serif;">
    <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="background-color: #f5f5f5; padding: 24px 0;">
      <tr>
        <td align="center">
          <table role="presentation" cellpadding="0" cellspacing="0" width="640" style="max-width: 640px; width: 100%; background-color: #ffffff; border-radius: 10px; overflow: hidden;">
            <tr>
              <td style="padding: 24px 24px 12px; text-align: center; border-bottom: 1px solid #efefef;">
                <img src="{{logo_url}}" alt="{{app_name}}" width="140" style="display: inline-block; border: 0;" />
              </td>
            </tr>
            <tr>
              <td style="padding: 24px;">
                <h2 style="margin: 0 0 12px; color: #111111;">Booking Awaiting Payment Confirmation</h2>
                <p style="margin: 0 0 16px; color: #444444; line-height: 1.6;">
                  Hello {{recipientName}}, a booking payment was submitted and is awaiting your confirmation.
                </p>

                <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="border-collapse: collapse;">
                  <tr>
                    <td style="padding: 10px 0; color: #666666; width: 220px;">Booking Reference</td>
                    <td style="padding: 10px 0; color: #111111; font-weight: 600;">{{bookingReferenceDisplay}}</td>
                  </tr>
                  <tr>
                    <td style="padding: 10px 0; color: #666666;">Booking Status</td>
                    <td style="padding: 10px 0; color: #111111;">
                      <span style="{{bookingStatusBadgeStyle}}">{{bookingStatusLabel}}</span>
                    </td>
                  </tr>
                  <tr>
                    <td style="padding: 10px 0; color: #666666;">Payment Status</td>
                    <td style="padding: 10px 0; color: #111111;">
                      <span style="{{paymentStatusBadgeStyle}}">{{paymentStatusLabel}}</span>
                    </td>
                  </tr>
                  <tr>
                    <td style="padding: 10px 0; color: #666666;">Merchant</td>
                    <td style="padding: 10px 0; color: #111111;">{{sellerName}}</td>
                  </tr>
                  <tr>
                    <td style="padding: 10px 0; color: #666666;">Service</td>
                    <td style="padding: 10px 0; color: #111111;">{{serviceTitle}}</td>
                  </tr>
                  <tr>
                    <td style="padding: 10px 0; color: #666666;">Guest Name</td>
                    <td style="padding: 10px 0; color: #111111;">{{guestName}}</td>
                  </tr>
                  <tr>
                    <td style="padding: 10px 0; color: #666666;">Guest Email</td>
                    <td style="padding: 10px 0; color: #111111;">{{guestEmail}}</td>
                  </tr>
                  <tr>
                    <td style="padding: 10px 0; color: #666666; vertical-align: top;">Selected Courts and Timeslot</td>
                    <td style="padding: 10px 0; color: #111111; line-height: 1.5;">{{selectedCourtsAndTimeslotSummary}}</td>
                  </tr>
                  {{#if hasMultipleSlotDetails}}
                  <tr>
                    <td style="padding: 10px 0; color: #666666; vertical-align: top;">Booked Slots</td>
                    <td style="padding: 10px 0; color: #111111;">
                      {{#each slotDetails}}
                      <div style="margin-bottom: 6px;">
                        <strong>{{bookingNumber}}</strong> • {{serviceTitle}}<br />
                        <span style="color: #4b5563;">{{scheduledDate}} | {{scheduledStartTime}} - {{scheduledEndTime}}</span>
                        <div style="margin-top: 4px;">
                          <span style="{{statusBadgeStyle}}">{{status}}</span>
                        </div>
                      </div>
                      {{/each}}
                    </td>
                  </tr>
                  {{/if}}
                  <tr>
                    <td style="padding: 10px 0; color: #666666;">Payment Reference</td>
                    <td style="padding: 10px 0; color: #111111;">{{paymentReference}}</td>
                  </tr>
                  <tr>
                    <td style="padding: 10px 0; color: #666666;">Payment Notified At</td>
                    <td style="padding: 10px 0; color: #111111;">{{paymentNotifiedAt}}</td>
                  </tr>
                  <tr>
                    <td style="padding: 12px 0; color: #666666; border-top: 1px solid #efefef;">Total Amount</td>
                    <td style="padding: 12px 0; color: #111111; font-size: 18px; font-weight: 700; border-top: 1px solid #efefef;">
                      {{currency}} {{amount}}
                    </td>
                  </tr>
                </table>
                <p style="margin: 16px 0 0; color: #444444; line-height: 1.6;">
                  For any issues or concerns, please contact 09399275311 or email us at ulrakpickleballhub@gmail.com
                </p>
              </td>
            </tr>
            <tr>
              <td style="padding: 16px 24px 24px; color: #888888; font-size: 12px; border-top: 1px solid #efefef;">
                {{footer}}
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
