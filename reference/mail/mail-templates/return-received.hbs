<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Return Items Received - {{app_name}}</title>
  <!--[if mso]>
  <style type="text/css">
    table { border-collapse: collapse; }
    .wrapper { width: 100% !important; }
    .container { width: 480px !important; }
  </style>
  <![endif]-->
</head>
<body style="margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; line-height: 1.5; color: #1a1a1a; background-color: #f5f5f5; -webkit-font-smoothing: antialiased;">
  <!-- Wrapper -->
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #f5f5f5;">
    <tr>
      <td align="center" style="padding: 40px 20px;">
        <!-- Container -->
        <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="max-width: 480px; background-color: #ffffff; border-radius: 12px; overflow: hidden;">

          <!-- Logo -->
          {{#if logo_url}}
          <tr>
            <td align="center" style="padding: 30px 30px 0;">
              <img src="{{logo_url}}" alt="{{app_name}}" width="150" style="display: block; max-width: 150px; height: auto;">
            </td>
          </tr>
          {{/if}}

          <!-- Header with Icon -->
          <tr>
            <td align="center" style="padding: 30px 30px 30px; border-bottom: 1px solid #f0f0f0;">
              <!-- Icon Circle -->
              <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td align="center" style="width: 64px; height: 64px; background-color: #e0f2fe; border-radius: 50%;">
                    <img src="https://img.icons8.com/ios-filled/50/3b82f6/package.png" alt="Received" width="32" height="32" style="display: block;">
                  </td>
                </tr>
              </table>
              <h1 style="margin: 20px 0 8px; font-size: 24px; font-weight: 600; color: #1a1a1a;">Items Received</h1>
              <p style="margin: 0; color: #666666; font-size: 15px;">Your return has been received and inspected</p>
            </td>
          </tr>

          <!-- Content -->
          <tr>
            <td style="padding: 30px;">
              <!-- Greeting -->
              <p style="margin: 0 0 8px; font-size: 18px; color: #1a1a1a;">Hi {{userName}},</p>
              <p style="margin: 0 0 30px; color: #666666; font-size: 15px; line-height: 1.6;">{{body}}</p>

              <!-- Return Details Section -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 30px;">
                <tr>
                  <td style="padding-bottom: 12px; border-bottom: 1px solid #f0f0f0;">
                    <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td style="padding-right: 10px; vertical-align: middle;">
                          <img src="https://img.icons8.com/ios-filled/20/999999/document.png" alt="" width="20" height="20">
                        </td>
                        <td style="font-size: 13px; font-weight: 600; color: #999999; text-transform: uppercase; letter-spacing: 0.5px;">
                          Return Details
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
                <tr>
                  <td style="padding-top: 16px;">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td style="padding: 6px 0; font-size: 14px; color: #666666;">Return Number</td>
                        <td align="right" style="padding: 6px 0; font-size: 14px; font-weight: 600; color: #1a1a1a;">{{#if return_number}}{{return_number}}{{else}}#{{entityId}}{{/if}}</td>
                      </tr>
                      {{#if order_number}}
                      <tr>
                        <td style="padding: 6px 0; font-size: 14px; color: #666666;">Order Number</td>
                        <td align="right" style="padding: 6px 0; font-size: 14px; font-weight: 600; color: #1a1a1a;">{{order_number}}</td>
                      </tr>
                      {{/if}}
                      {{#if received_date}}
                      <tr>
                        <td style="padding: 6px 0; font-size: 14px; color: #666666;">Received Date</td>
                        <td align="right" style="padding: 6px 0; font-size: 14px; font-weight: 600; color: #1a1a1a;">{{received_date}}</td>
                      </tr>
                      {{/if}}
                    </table>
                  </td>
                </tr>
              </table>

              <!-- Inspection Results Section -->
              {{#if inspection_status}}
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 30px; background-color: #eff6ff; border-radius: 8px; border-left: 4px solid #3b82f6;">
                <tr>
                  <td style="padding: 20px;">
                    <p style="margin: 0 0 16px; font-size: 14px; font-weight: 600; color: #1d4ed8; text-transform: uppercase; letter-spacing: 0.5px;">Inspection Results</p>
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td style="padding: 6px 0; font-size: 14px; font-weight: 600; color: #1d4ed8;">Status:</td>
                        <td align="right" style="padding: 6px 0; font-size: 14px; font-weight: 600; color: {{#if (eq inspection_status 'approved')}}#16a34a{{else}}#dc2626{{/if}};">{{inspection_status}}</td>
                      </tr>
                      {{#if inspection_notes}}
                      <tr>
                        <td colspan="2" style="padding: 12px 0 6px;">
                          <p style="margin: 0 0 4px; font-size: 14px; font-weight: 600; color: #1d4ed8;">Notes:</p>
                          <p style="margin: 0; font-size: 14px; color: #1a1a1a; line-height: 1.5;">{{inspection_notes}}</p>
                        </td>
                      </tr>
                      {{/if}}
                      {{#if inspector_name}}
                      <tr>
                        <td style="padding: 6px 0; font-size: 14px; font-weight: 600; color: #1d4ed8;">Inspected By:</td>
                        <td align="right" style="padding: 6px 0; font-size: 14px; color: #1a1a1a;">{{inspector_name}}</td>
                      </tr>
                      {{/if}}
                    </table>
                  </td>
                </tr>
              </table>
              {{/if}}

              <!-- Items Section -->
              {{#if return_items}}
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 30px;">
                <tr>
                  <td style="padding-bottom: 12px; border-bottom: 1px solid #f0f0f0;">
                    <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td style="padding-right: 10px; vertical-align: middle;">
                          <img src="https://img.icons8.com/ios-filled/20/999999/box.png" alt="" width="20" height="20">
                        </td>
                        <td style="font-size: 13px; font-weight: 600; color: #999999; text-transform: uppercase; letter-spacing: 0.5px;">
                          Items Received
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
                {{#each return_items}}
                <tr>
                  <td style="padding: 16px 0; border-bottom: 1px solid #f5f5f5;">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td width="56" valign="top" style="padding-right: 16px;">
                          {{#if image_url}}
                          <img src="{{image_url}}" alt="{{product_name}}" width="56" height="56" style="display: block; border-radius: 8px; background-color: #f5f5f5; object-fit: cover;">
                          {{else}}
                          <div style="width: 56px; height: 56px; background-color: #f5f5f5; border-radius: 8px;"></div>
                          {{/if}}
                        </td>
                        <td valign="top">
                          <p style="margin: 0 0 4px; font-size: 14px; font-weight: 500; color: #1a1a1a;">{{product_name}}</p>
                          {{#if variant_name}}<p style="margin: 0; font-size: 13px; color: #999999;">{{variant_name}}</p>{{/if}}
                          <p style="margin: 2px 0 0; font-size: 13px; color: #666666;">Quantity: <span style="color: #3b82f6; font-weight: 600;">{{quantity_returning}}</span></p>
                          {{#if item_status}}
                          <p style="margin: 4px 0 0; font-size: 13px; font-weight: 600; color: {{#if (eq item_status 'approved')}}#16a34a{{else}}#dc2626{{/if}};">{{item_status}}</p>
                          {{/if}}
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
                {{/each}}

                <!-- Refund Total -->
                {{#if ../refund_amount}}
                <tr>
                  <td style="padding-top: 20px;">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #fafafa; border-radius: 8px;">
                      <tr>
                        <td style="padding: 16px;">
                          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="border-top: 1px solid #e0e0e0;">
                            <tr>
                              <td style="padding: 16px 0 0; font-size: 16px; font-weight: 600; color: #1a1a1a;">{{#if (eq ../inspection_status 'approved')}}Refund Amount{{else}}Potential Refund{{/if}}</td>
                              <td align="right" style="padding: 16px 0 0; font-size: 16px; font-weight: 600; color: #3b82f6;">{{../refund_amount}}</td>
                            </tr>
                          </table>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
                {{/if}}
              </table>
              {{else}}
              {{#if refund_amount}}
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 30px; background-color: #fafafa; border-radius: 8px;">
                <tr>
                  <td style="padding: 16px;">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td style="font-size: 16px; font-weight: 600; color: #1a1a1a;">{{#if (eq inspection_status 'approved')}}Refund Amount{{else}}Potential Refund{{/if}}</td>
                        <td align="right" style="font-size: 16px; font-weight: 600; color: #3b82f6;">{{refund_amount}}</td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>
              {{/if}}
              {{/if}}

              <!-- CTA Button -->
              {{#if actionUrl}}
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 30px;">
                <tr>
                  <td align="center">
                    <a href="{{domain}}{{actionUrl}}" style="display: inline-block; background-color: #3b82f6; color: #ffffff; padding: 14px 32px; text-decoration: none; border-radius: 8px; font-weight: 600; font-size: 14px;">View Return Details</a>
                  </td>
                </tr>
              </table>
              {{/if}}

              <!-- Next Steps -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 20px; background-color: #eff6ff; border-radius: 8px; border: 1px solid #bfdbfe;">
                <tr>
                  <td style="padding: 16px;">
                    <p style="margin: 0 0 12px; font-size: 14px; font-weight: 600; color: #1d4ed8;">What happens next?</p>
                    {{#if (eq inspection_status 'approved')}}
                    <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td style="padding: 4px 0; font-size: 14px; color: #1a1a1a;">1. Refund processing will begin within 1-2 business days</td>
                      </tr>
                      <tr>
                        <td style="padding: 4px 0; font-size: 14px; color: #1a1a1a;">2. You will receive a confirmation email once refund is processed</td>
                      </tr>
                      <tr>
                        <td style="padding: 4px 0; font-size: 14px; color: #1a1a1a;">3. Refunds typically appear in your account within 3-5 business days</td>
                      </tr>
                    </table>
                    {{else if (eq inspection_status 'rejected')}}
                    <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td style="padding: 4px 0; font-size: 14px; color: #1a1a1a;">1. We will contact you regarding the inspection findings</td>
                      </tr>
                      <tr>
                        <td style="padding: 4px 0; font-size: 14px; color: #1a1a1a;">2. Items may be returned to you or alternative arrangements made</td>
                      </tr>
                      <tr>
                        <td style="padding: 4px 0; font-size: 14px; color: #1a1a1a;">3. Please check your email for further communication</td>
                      </tr>
                    </table>
                    {{else}}
                    <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td style="padding: 4px 0; font-size: 14px; color: #1a1a1a;">1. Items are being inspected for condition and eligibility</td>
                      </tr>
                      <tr>
                        <td style="padding: 4px 0; font-size: 14px; color: #1a1a1a;">2. You will receive an update once inspection is complete</td>
                      </tr>
                      <tr>
                        <td style="padding: 4px 0; font-size: 14px; color: #1a1a1a;">3. If approved, refund processing will begin</td>
                      </tr>
                    </table>
                    {{/if}}
                  </td>
                </tr>
              </table>

            </td>
          </tr>

          <!-- Closing -->
          <tr>
            <td align="center" style="padding: 20px 30px 30px;">
              <p style="margin: 0; color: #666666; font-size: 14px;">Thank you for your understanding!</p>
              <p style="margin: 8px 0 0; color: #999999; font-size: 13px;">{{app_name}}</p>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td align="center" style="padding: 20px 30px; background-color: #fafafa; border-top: 1px solid #f0f0f0;">
              <p style="margin: 0 0 8px; font-size: 12px; color: #999999;">{{footer}}</p>
              <p style="margin: 0; font-size: 12px; color: #999999;">This is an automated message from {{app_name}}. Please do not reply.</p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
