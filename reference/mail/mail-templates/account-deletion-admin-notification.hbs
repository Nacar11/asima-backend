<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>New Account Deletion Request - Adtokart</title>
  <!--[if mso]>
  <style type="text/css">
    table { border-collapse: collapse; }
    .wrapper { width: 100% !important; }
    .container { width: 480px !important; }
  </style>
  <![endif]-->
</head>
<body style="margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; line-height: 1.5; color: #1a1a1a; background-color: #f5f5f5; -webkit-font-smoothing: antialiased;">
  <!-- Wrapper -->
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #f5f5f5;">
    <tr>
      <td align="center" style="padding: 40px 20px;">
        <!-- Container -->
        <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="max-width: 480px; background-color: #ffffff; border-radius: 12px; overflow: hidden;">

          <!-- Logo -->
          <tr>
            <td align="center" style="padding: 30px 30px 20px;">
              <img src="{{logo_url}}" alt="{{app_name}}" width="150" style="display: block; max-width: 150px; height: auto;">
            </td>
          </tr>

          <!-- Header with Alert -->
          <tr>
            <td align="center" style="padding: 30px 30px 20px; background-color: #dc2626; color: white;">
              <h1 style="margin: 0; font-size: 24px; font-weight: 600; color: white;">🚨 New Account Deletion Request</h1>
            </td>
          </tr>

          <!-- Alert Badge -->
          <tr>
            <td style="padding: 20px 30px 10px;">
              <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td style="padding: 8px 16px; background-color: #fee2e2; color: #dc2626; border-radius: 20px; font-weight: 600; font-size: 13px; text-transform: uppercase; letter-spacing: 0.5px;">
                    ACTION REQUIRED
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Content -->
          <tr>
            <td style="padding: 10px 30px 30px;">
              <p style="margin: 0 0 20px; color: #666666; font-size: 15px; line-height: 1.6;">
                A new account deletion request has been submitted and requires admin review.
              </p>

              <!-- Reference Number Box -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 20px;">
                <tr>
                  <td align="center" style="padding: 24px; background-color: #eff6ff; border-radius: 8px; border: 1px solid #bfdbfe;">
                    <p style="margin: 0 0 12px; font-size: 13px; color: #666666; text-transform: uppercase; letter-spacing: 0.5px;">Reference Number</p>
                    <p style="margin: 0; font-size: 24px; font-weight: 700; color: #3b82f6; letter-spacing: 2px; font-family: 'Courier New', monospace;">{{reference_number}}</p>
                  </td>
                </tr>
              </table>

              <!-- Request Details -->
              <p style="margin: 0 0 12px; font-size: 16px; font-weight: 600; color: #1a1a1a;">Request Details:</p>
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 20px;">
                <tr>
                  <td style="padding: 8px 0; font-size: 14px; color: #666666; border-bottom: 1px solid #f0f0f0;">Email:</td>
                  <td style="padding: 8px 0; font-size: 14px; font-weight: 600; color: #1a1a1a; border-bottom: 1px solid #f0f0f0;">{{email}}</td>
                </tr>
                <tr>
                  <td style="padding: 8px 0; font-size: 14px; color: #666666; border-bottom: 1px solid #f0f0f0;">Full Name:</td>
                  <td style="padding: 8px 0; font-size: 14px; color: #1a1a1a; border-bottom: 1px solid #f0f0f0;">{{full_name}}</td>
                </tr>
                <tr>
                  <td style="padding: 8px 0; font-size: 14px; color: #666666; border-bottom: 1px solid #f0f0f0;">Reason:</td>
                  <td style="padding: 8px 0; font-size: 14px; color: #1a1a1a; border-bottom: 1px solid #f0f0f0;">{{reason}}</td>
                </tr>
                <tr>
                  <td style="padding: 8px 0; font-size: 14px; color: #666666;">Submitted:</td>
                  <td style="padding: 8px 0; font-size: 14px; color: #1a1a1a;">{{created_at}}</td>
                </tr>
              </table>

              <!-- Next Steps -->
              <p style="margin: 0 0 12px; font-size: 16px; font-weight: 600; color: #1a1a1a;">Next Steps:</p>
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 20px;">
                <tr>
                  <td style="padding: 16px; background-color: #f9fafb; border-radius: 8px;">
                    <p style="margin: 6px 0; font-size: 14px; color: #666666;">1. Review the deletion request in the admin panel</p>
                    <p style="margin: 6px 0; font-size: 14px; color: #666666;">2. Verify the user's identity and account status</p>
                    <p style="margin: 6px 0; font-size: 14px; color: #666666;">3. Check for any pending orders or transactions</p>
                    <p style="margin: 6px 0; font-size: 14px; color: #666666;">4. Process the deletion request or contact the user if needed</p>
                    <p style="margin: 6px 0; font-size: 14px; color: #666666;">5. Update the request status once completed</p>
                  </td>
                </tr>
              </table>

              <!-- Reminder -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-top: 20px;">
                <tr>
                  <td style="padding: 16px; background-color: #fef3c7; border-radius: 8px; border: 1px solid #fde68a;">
                    <p style="margin: 0; font-size: 13px; color: #92400e; line-height: 1.5;">
                      <strong>⏰ Reminder:</strong> Account deletion requests should be processed within 30 days as per our policy and Google Play requirements.
                    </p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td align="center" style="padding: 20px 30px; background-color: #fafafa; border-top: 1px solid #f0f0f0;">
              <p style="margin: 0 0 8px; font-size: 12px; color: #999999;">Adtokart Admin System</p>
              <p style="margin: 0; font-size: 12px; color: #999999;">This is an automated notification. Please do not reply.</p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
