<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Account Deletion Request Received - Adtokart</title>
  <!--[if mso]>
  <style type="text/css">
    table { border-collapse: collapse; }
    .wrapper { width: 100% !important; }
    .container { width: 480px !important; }
  </style>
  <![endif]-->
</head>
<body style="margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; line-height: 1.5; color: #1a1a1a; background-color: #f5f5f5; -webkit-font-smoothing: antialiased;">
  <!-- Wrapper -->
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #f5f5f5;">
    <tr>
      <td align="center" style="padding: 40px 20px;">
        <!-- Container -->
        <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="max-width: 480px; background-color: #ffffff; border-radius: 12px; overflow: hidden;">

          <!-- Logo -->
          <tr>
            <td align="center" style="padding: 30px 30px 0;">
              <img src="{{logo_url}}" alt="{{app_name}}" width="150" style="display: block; max-width: 150px; height: auto;">
            </td>
          </tr>

          <!-- Header with Icon -->
          <tr>
            <td align="center" style="padding: 30px 30px 30px; border-bottom: 1px solid #f0f0f0;">
              <!-- Icon Circle -->
              <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td align="center" style="width: 64px; height: 64px; background-color: #e0f2fe; border-radius: 50%;">
                    <img src="https://img.icons8.com/ios-filled/50/3b82f6/checkmark--v1.png" alt="Confirmed" width="32" height="32" style="display: block;">
                  </td>
                </tr>
              </table>
              <h1 style="margin: 20px 0 8px; font-size: 24px; font-weight: 600; color: #1a1a1a;">Account Deletion Request Received</h1>
              <p style="margin: 0; color: #666666; font-size: 15px;">We've received your request</p>
            </td>
          </tr>

          <!-- Content -->
          <tr>
            <td style="padding: 30px;">
              <!-- Greeting -->
              <p style="margin: 0 0 8px; font-size: 18px; color: #1a1a1a;">Dear {{fullName}},</p>
              <p style="margin: 0 0 20px; color: #666666; font-size: 15px; line-height: 1.6;">
                We have received your request to delete your Adtokart account associated with <strong>{{email}}</strong>.
              </p>

              <!-- Reference Number Box -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 20px;">
                <tr>
                  <td align="center" style="padding: 24px; background-color: #eff6ff; border-radius: 8px; border: 1px solid #bfdbfe;">
                    <p style="margin: 0 0 12px; font-size: 13px; color: #666666; text-transform: uppercase; letter-spacing: 0.5px;">Your Reference Number</p>
                    <p style="margin: 0; font-size: 24px; font-weight: 700; color: #3b82f6; letter-spacing: 2px; font-family: 'Courier New', monospace;">{{referenceNumber}}</p>
                    <p style="margin: 12px 0 0; font-size: 13px; color: #999999;">Please save this for your records</p>
                  </td>
                </tr>
              </table>

              <!-- What Happens Next -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 20px;">
                <tr>
                  <td style="padding: 20px; background-color: #f9fafb; border-radius: 8px;">
                    <p style="margin: 0 0 12px; font-size: 16px; font-weight: 600; color: #1a1a1a;">📋 What Happens Next?</p>
                    <p style="margin: 6px 0; font-size: 14px; color: #666666;">✓ Your request will be reviewed by our admin team</p>
                    <p style="margin: 6px 0; font-size: 14px; color: #666666;">✓ Processing will be completed within <strong>{{estimatedDays}} days</strong></p>
                    <p style="margin: 6px 0; font-size: 14px; color: #666666;">✓ Your account will remain active until processing is complete</p>
                    <p style="margin: 6px 0; font-size: 14px; color: #666666;">✓ You will be notified once the deletion is processed</p>
                  </td>
                </tr>
              </table>

              <!-- What Will Be Deleted -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 20px;">
                <tr>
                  <td style="padding: 20px; background-color: #f9fafb; border-radius: 8px;">
                    <p style="margin: 0 0 12px; font-size: 16px; font-weight: 600; color: #1a1a1a;">🗑️ What Will Be Deleted?</p>
                    <p style="margin: 0 0 8px; font-size: 14px; font-weight: 600; color: #666666;">Immediately (after admin approval):</p>
                    <p style="margin: 4px 0; font-size: 14px; color: #666666;">• Profile information (name, photo, bio)</p>
                    <p style="margin: 4px 0; font-size: 14px; color: #666666;">• Email address and phone number</p>
                    <p style="margin: 4px 0; font-size: 14px; color: #666666;">• Saved addresses and payment methods</p>
                    <p style="margin: 4px 0; font-size: 14px; color: #666666;">• Preferences, settings, and browsing history</p>
                    <p style="margin: 4px 0; font-size: 14px; color: #666666;">• Wishlists and shopping cart items</p>
                  </td>
                </tr>
              </table>

              <!-- What Will Be Retained -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 20px;">
                <tr>
                  <td style="padding: 20px; background-color: #f9fafb; border-radius: 8px;">
                    <p style="margin: 0 0 12px; font-size: 16px; font-weight: 600; color: #1a1a1a;">📦 What Will Be Retained?</p>
                    <p style="margin: 0 0 8px; font-size: 14px; font-weight: 600; color: #666666;">For legal compliance:</p>
                    <p style="margin: 4px 0; font-size: 14px; color: #666666;"><strong>Transaction records (7 years):</strong> Required for tax compliance</p>
                    <p style="margin: 4px 0; font-size: 14px; color: #666666;"><strong>Fraud prevention data (2-3 years):</strong> To protect platform integrity</p>
                    <p style="margin: 4px 0; font-size: 14px; color: #666666;"><strong>Legal dispute records:</strong> As required by law</p>
                    <p style="margin: 12px 0 0; font-size: 13px; color: #999999; font-style: italic;">Note: Retained data will be pseudonymized and cannot be linked back to you.</p>
                  </td>
                </tr>
              </table>

              <!-- Warning -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 20px;">
                <tr>
                  <td style="padding: 16px; background-color: #fef3c7; border-radius: 8px; border: 1px solid #fde68a;">
                    <p style="margin: 0; font-size: 13px; color: #92400e; line-height: 1.5;">
                      <strong>⚠️ Important:</strong> This action cannot be undone. If you change your mind, please contact our support team immediately using your reference number: <strong>{{referenceNumber}}</strong>
                    </p>
                  </td>
                </tr>
              </table>

              <p style="margin: 0; color: #666666; font-size: 14px; line-height: 1.6;">
                If you have any questions or concerns about this request, please contact us at <a href="mailto:support@adtokart.com" style="color: #3b82f6; text-decoration: none;">support@adtokart.com</a> and include your reference number.
              </p>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td align="center" style="padding: 20px 30px; background-color: #fafafa; border-top: 1px solid #f0f0f0;">
              <p style="margin: 0 0 8px; font-size: 12px; color: #999999;">Best regards, The Adtokart Team</p>
              <p style="margin: 0; font-size: 12px; color: #999999;">This is an automated message. Please do not reply.</p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
