<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Booking Confirmed - {{app_name}}</title>
  </head>
  <body style="margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; line-height: 1.5; color: #1a1a1a; background-color: #f3f4f6;">
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #f3f4f6;">
      <tr>
        <td align="center" style="padding: 32px 16px;">
          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="max-width: 640px; background-color: #ffffff; border-radius: 12px; overflow: hidden;">
            {{#if logo_url}}
            <tr>
              <td align="center" style="padding: 24px 24px 0;">
                <img src="{{logo_url}}" alt="{{app_name}}" width="150" style="display: block; max-width: 150px; height: auto;" />
              </td>
            </tr>
            {{/if}}

            <tr>
              <td align="center" style="padding: 22px 24px 24px; border-bottom: 1px solid #f0f0f0;">
                <h1 style="margin: 0; font-size: 24px; font-weight: 700; color: #1f2937;">Booking Confirmed</h1>
                <p style="margin: 8px 0 0; color: #6b7280; font-size: 15px;">Your booking has been approved and is now confirmed.</p>
              </td>
            </tr>

            <tr>
              <td style="padding: 24px;">
                <p style="margin: 0 0 8px; font-size: 18px; color: #1f2937;">Hi {{guestName}},</p>
                <p style="margin: 0 0 18px; color: #6b7280; font-size: 14px;">Here are your final booking details for easy reference.</p>

                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="border: 1px solid #e5e7eb; border-radius: 10px; background-color: #f8fafc; margin-bottom: 18px;">
                  <tr>
                    <td style="padding: 14px 16px;">
                      <div style="font-size: 14px; color: #111827; font-weight: 700; margin-bottom: 8px;">Booking Summary</div>
                      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="border-collapse: collapse;">
                        <tr>
                          <td style="padding: 6px 0; font-size: 13px; color: #6b7280;">Booking Reference</td>
                          <td align="right" style="padding: 6px 0; font-size: 13px; font-weight: 600; color: #111827;">{{bookingReferenceDisplay}}</td>
                        </tr>
                        <tr>
                          <td style="padding: 6px 0; font-size: 13px; color: #6b7280;">Booking Status</td>
                          <td align="right" style="padding: 6px 0;">
                            <span style="{{bookingStatusBadgeStyle}}">{{bookingStatusLabel}}</span>
                          </td>
                        </tr>
                        <tr>
                          <td style="padding: 6px 0; font-size: 13px; color: #6b7280;">Payment Status</td>
                          <td align="right" style="padding: 6px 0;">
                            <span style="{{paymentStatusBadgeStyle}}">{{paymentStatusLabel}}</span>
                          </td>
                        </tr>
                        <tr>
                          <td style="padding: 6px 0; font-size: 13px; color: #6b7280;">Slot Count</td>
                          <td align="right" style="padding: 6px 0; font-size: 13px; font-weight: 600; color: #111827;">{{slotCount}}</td>
                        </tr>
                        <tr>
                          <td style="padding: 6px 0; font-size: 13px; color: #6b7280; vertical-align: top;">Selected Courts and Timeslot</td>
                          <td align="right" style="padding: 6px 0; font-size: 13px; font-weight: 600; color: #111827; line-height: 1.5;">{{selectedCourtsAndTimeslotSummary}}</td>
                        </tr>
                        <tr>
                          <td style="padding: 6px 0; font-size: 13px; color: #6b7280;">Timezone</td>
                          <td align="right" style="padding: 6px 0; font-size: 13px; font-weight: 600; color: #111827;">{{timezoneLabel}}</td>
                        </tr>
                      </table>
                    </td>
                  </tr>
                </table>

                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="border: 1px solid #e5e7eb; border-radius: 10px; padding: 14px 16px; margin-bottom: 18px;">
                  <tr>
                    <td style="padding: 6px 0; font-size: 13px; color: #6b7280;">Merchant</td>
                    <td align="right" style="padding: 6px 0; font-size: 13px; font-weight: 600; color: #111827;">{{sellerName}}</td>
                  </tr>
                  <tr>
                    <td style="padding: 6px 0; font-size: 13px; color: #6b7280;">Service</td>
                    <td align="right" style="padding: 6px 0; font-size: 13px; font-weight: 600; color: #111827;">{{serviceTitle}}</td>
                  </tr>
                  <tr>
                    <td style="padding: 6px 0; font-size: 13px; color: #6b7280;">Service Date</td>
                    <td align="right" style="padding: 6px 0; font-size: 13px; font-weight: 600; color: #111827;">{{scheduledDate}}</td>
                  </tr>
                  <tr>
                    <td style="padding: 6px 0; font-size: 13px; color: #6b7280;">Service Time</td>
                    <td align="right" style="padding: 6px 0; font-size: 13px; font-weight: 600; color: #111827;">{{scheduledStartTime}} - {{scheduledEndTime}}</td>
                  </tr>
                  <tr>
                    <td style="padding: 6px 0; font-size: 13px; color: #6b7280;">Customer Name</td>
                    <td align="right" style="padding: 6px 0; font-size: 13px; font-weight: 600; color: #111827;">{{primaryGuestName}}</td>
                  </tr>
                  <tr>
                    <td style="padding: 6px 0; font-size: 13px; color: #6b7280;">Customer Email</td>
                    <td align="right" style="padding: 6px 0; font-size: 13px; font-weight: 600; color: #111827;">{{primaryGuestEmail}}</td>
                  </tr>
                  <tr>
                    <td style="padding: 6px 0; font-size: 13px; color: #6b7280;">Customer Number</td>
                    <td align="right" style="padding: 6px 0; font-size: 13px; font-weight: 600; color: #111827;">{{primaryGuestPhone}}</td>
                  </tr>
                  <tr>
                    <td style="padding: 6px 0; font-size: 13px; color: #6b7280;">Total Persons</td>
                    <td align="right" style="padding: 6px 0; font-size: 13px; font-weight: 600; color: #111827;">{{guestCount}}</td>
                  </tr>
                  <tr>
                    <td style="padding: 6px 0; font-size: 13px; color: #6b7280;">Paid Amount</td>
                    <td align="right" style="padding: 6px 0; font-size: 14px; font-weight: 700; color: #2563eb;">{{currency}} {{amount}}</td>
                  </tr>
                </table>

                {{#if hasMultipleSlotDetails}}
                <div style="margin: 4px 0 14px; color: #6b7280; font-size: 12px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase;">Booked Slots</div>
                {{#each slotDetails}}
                <div style="padding: 10px 12px; border: 1px solid #e5e7eb; border-radius: 8px; margin-bottom: 8px;">
                  <div style="color: #111827; font-size: 13px; font-weight: 700;">{{bookingNumber}} • {{serviceTitle}}</div>
                  <div style="color: #4b5563; font-size: 13px; margin-top: 4px;">{{scheduledDate}} | {{scheduledStartTime}} - {{scheduledEndTime}}</div>
                  <div style="margin-top: 6px;">
                    <span style="{{statusBadgeStyle}}">{{status}}</span>
                  </div>
                </div>
                {{/each}}
                {{/if}}

                {{#if actionUrl}}
                <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="margin-top: 20px;">
                  <tr>
                    <td align="center">
                      <a href="{{domain}}{{actionUrl}}" style="display: inline-block; background: #2563eb; color: #ffffff; text-decoration: none; font-weight: 600; font-size: 16px; padding: 12px 22px; border-radius: 8px;">{{ctaLabel}}</a>
                    </td>
                  </tr>
                </table>
                {{/if}}

                <p style="margin: 18px 0 0; color: #6b7280; font-size: 13px; line-height: 1.6;">Keep this email for reference. You can use your booking number and email address to check booking status.</p>
              </td>
            </tr>

            <tr>
              <td align="center" style="padding: 20px 24px; background-color: #fafafa; border-top: 1px solid #f0f0f0;">
                <p style="margin: 0 0 8px; font-size: 12px; color: #999999;">{{footer}}</p>
                <p style="margin: 0; font-size: 12px; color: #999999;">This is an automated message. Please do not reply.</p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
