<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Order Cancelled - {{app_name}}</title>
  <!--[if mso]>
  <style type="text/css">
    table { border-collapse: collapse; }
    .wrapper { width: 100% !important; }
    .container { width: 480px !important; }
  </style>
  <![endif]-->
</head>
<body style="margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; line-height: 1.5; color: #1a1a1a; background-color: #f5f5f5; -webkit-font-smoothing: antialiased;">
  <!-- Wrapper -->
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #f5f5f5;">
    <tr>
      <td align="center" style="padding: 40px 20px;">
        <!-- Container -->
        <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="max-width: 480px; background-color: #ffffff; border-radius: 12px; overflow: hidden;">

          <!-- Logo -->
          {{#if logo_url}}
          <tr>
            <td align="center" style="padding: 30px 30px 0;">
              <img src="{{logo_url}}" alt="{{app_name}}" width="150" style="display: block; max-width: 150px; height: auto;">
            </td>
          </tr>
          {{/if}}

          <!-- Header with Icon -->
          <tr>
            <td align="center" style="padding: 30px 30px 30px; border-bottom: 1px solid #f0f0f0;">
              <!-- Icon Circle -->
              <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td align="center" style="width: 64px; height: 64px; background-color: #fee2e2; border-radius: 50%;">
                    <img src="https://img.icons8.com/ios-filled/50/ef4444/cancel.png" alt="Cancelled" width="32" height="32" style="display: block;">
                  </td>
                </tr>
              </table>
              <h1 style="margin: 20px 0 8px; font-size: 24px; font-weight: 600; color: #1a1a1a;">Order Cancelled</h1>
              <p style="margin: 0; color: #666666; font-size: 15px;">Your order has been cancelled</p>
            </td>
          </tr>

          <!-- Content -->
          <tr>
            <td style="padding: 30px;">
              <!-- Greeting -->
              <p style="margin: 0 0 8px; font-size: 18px; color: #1a1a1a;">Hi {{userName}},</p>
              <p style="margin: 0 0 30px; color: #666666; font-size: 15px; line-height: 1.6;">{{body}}</p>

              <!-- Cancellation Notice -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 30px;">
                <tr>
                  <td align="center" style="padding: 20px; background-color: #fef2f2; border-radius: 8px; border: 1px solid #fecaca;">
                    <p style="margin: 0 0 4px; font-size: 16px; font-weight: 600; color: #dc2626;">This Order Has Been Cancelled</p>
                    <p style="margin: 0; font-size: 14px; color: #ef4444;">Any payment will be refunded within 5-10 business days</p>
                  </td>
                </tr>
              </table>

              <!-- Cancellation Reason -->
              {{#if return_reason}}
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 30px; background-color: #eff6ff; border-radius: 8px; border-left: 4px solid #3b82f6;">
                <tr>
                  <td style="padding: 16px;">
                    <p style="margin: 0 0 8px; font-size: 13px; font-weight: 600; color: #1d4ed8; text-transform: uppercase; letter-spacing: 0.5px;">Reason for Cancellation</p>
                    <p style="margin: 0; font-size: 14px; color: #1a1a1a; line-height: 1.5;">{{return_reason}}</p>
                  </td>
                </tr>
              </table>
              {{/if}}

              <!-- Order Details Section -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 30px;">
                <tr>
                  <td style="padding-bottom: 12px; border-bottom: 1px solid #f0f0f0;">
                    <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td style="padding-right: 10px; vertical-align: middle;">
                          <img src="https://img.icons8.com/ios-filled/20/999999/document.png" alt="" width="20" height="20">
                        </td>
                        <td style="font-size: 13px; font-weight: 600; color: #999999; text-transform: uppercase; letter-spacing: 0.5px;">
                          Order Details
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
                <tr>
                  <td style="padding-top: 16px;">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td style="padding: 6px 0; font-size: 14px; color: #666666;">Order Number</td>
                        <td align="right" style="padding: 6px 0; font-size: 14px; font-weight: 600; color: #1a1a1a;">{{#if order_number}}{{order_number}}{{else}}#{{entityId}}{{/if}}</td>
                      </tr>
                      {{#if seller_name}}
                      <tr>
                        <td style="padding: 6px 0; font-size: 14px; color: #666666;">Seller</td>
                        <td align="right" style="padding: 6px 0; font-size: 14px; font-weight: 600; color: #1a1a1a;">{{seller_name}}</td>
                      </tr>
                      {{/if}}
                      <tr>
                        <td style="padding: 6px 0; font-size: 14px; color: #666666;">Status</td>
                        <td align="right" style="padding: 6px 0; font-size: 14px; font-weight: 600; color: #dc2626;">Cancelled</td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>

              <!-- Items Section -->
              {{#if order_items}}
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 30px;">
                <tr>
                  <td style="padding-bottom: 12px; border-bottom: 1px solid #f0f0f0;">
                    <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td style="padding-right: 10px; vertical-align: middle;">
                          <img src="https://img.icons8.com/ios-filled/20/999999/box.png" alt="" width="20" height="20">
                        </td>
                        <td style="font-size: 13px; font-weight: 600; color: #999999; text-transform: uppercase; letter-spacing: 0.5px;">
                          Cancelled Items
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
                {{#each order_items}}
                <tr>
                  <td style="padding: 16px 0; border-bottom: 1px solid #f5f5f5; opacity: 0.7;">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td width="56" valign="top" style="padding-right: 16px;">
                          {{#if image_url}}
                          <img src="{{image_url}}" alt="{{product_name}}" width="56" height="56" style="display: block; border-radius: 8px; background-color: #f5f5f5; object-fit: cover; filter: grayscale(50%);">
                          {{else}}
                          <div style="width: 56px; height: 56px; background-color: #f5f5f5; border-radius: 8px;"></div>
                          {{/if}}
                        </td>
                        <td valign="top">
                          <p style="margin: 0 0 4px; font-size: 14px; font-weight: 500; color: #999999; text-decoration: line-through;">{{product_name}}</p>
                          {{#if variant_name}}<p style="margin: 0; font-size: 13px; color: #bbbbbb;">{{variant_name}}</p>{{/if}}
                          <p style="margin: 2px 0 0; font-size: 13px; color: #999999;">Qty: {{quantity}}</p>
                        </td>
                        <td align="right" valign="top" style="white-space: nowrap; padding-left: 12px;">
                          <p style="margin: 0; font-size: 14px; font-weight: 600; color: #999999; text-decoration: line-through;">{{total_price}}</p>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
                {{/each}}

                <!-- Totals -->
                <tr>
                  <td style="padding-top: 20px;">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #fafafa; border-radius: 8px; padding: 16px;">
                      <tr>
                        <td style="padding: 16px;">
                          {{#if subtotal}}
                          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                            <tr>
                              <td style="padding: 8px 0; font-size: 14px; color: #999999;">Subtotal</td>
                              <td align="right" style="padding: 8px 0; font-size: 14px; color: #999999; text-decoration: line-through;">{{subtotal}}</td>
                            </tr>
                          </table>
                          {{/if}}
                          {{#if shipping_amount}}
                          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                            <tr>
                              <td style="padding: 8px 0; font-size: 14px; color: #999999;">Shipping</td>
                              <td align="right" style="padding: 8px 0; font-size: 14px; color: #999999; text-decoration: line-through;">{{shipping_amount}}</td>
                            </tr>
                          </table>
                          {{/if}}
                          {{#if tax_amount}}
                          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                            <tr>
                              <td style="padding: 8px 0; font-size: 14px; color: #999999;">Tax</td>
                              <td align="right" style="padding: 8px 0; font-size: 14px; color: #999999; text-decoration: line-through;">{{tax_amount}}</td>
                            </tr>
                          </table>
                          {{/if}}
                          {{#if discount_amount}}
                          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                            <tr>
                              <td style="padding: 8px 0; font-size: 14px; color: #999999;">Discount</td>
                              <td align="right" style="padding: 8px 0; font-size: 14px; color: #999999;">-{{discount_amount}}</td>
                            </tr>
                          </table>
                          {{/if}}
                          {{#if amount}}
                          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="border-top: 1px solid #e0e0e0; margin-top: 8px;">
                            <tr>
                              <td style="padding: 16px 0 0; font-size: 16px; font-weight: 600; color: #999999;">Order Total</td>
                              <td align="right" style="padding: 16px 0 0; font-size: 16px; font-weight: 600; color: #dc2626; text-decoration: line-through;">{{amount}}</td>
                            </tr>
                          </table>
                          {{/if}}
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>
              {{/if}}

              <!-- Refund Information -->
              {{#if amount}}
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 30px; background-color: #f0fdf4; border-radius: 8px; border: 1px solid #bbf7d0;">
                <tr>
                  <td style="padding: 16px;">
                    <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td style="padding-right: 12px; vertical-align: top;">
                          <img src="https://img.icons8.com/ios-filled/24/22c55e/refund-2.png" alt="" width="24" height="24">
                        </td>
                        <td>
                          <p style="margin: 0 0 4px; font-size: 14px; font-weight: 600; color: #166534;">Refund Information</p>
                          <p style="margin: 0; font-size: 14px; color: #15803d; line-height: 1.5;">If you have already paid for this order, a refund of {{amount}} will be processed within 5-10 business days to your original payment method.</p>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>
              {{/if}}

              <!-- Help Section -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 20px; background-color: #eff6ff; border-radius: 8px; border: 1px solid #bfdbfe;">
                <tr>
                  <td style="padding: 16px;">
                    <p style="margin: 0 0 8px; font-size: 14px; font-weight: 600; color: #1d4ed8;">Need Help?</p>
                    <p style="margin: 0; font-size: 14px; color: #3b82f6; line-height: 1.5;">If you have any questions about this cancellation or need assistance, please contact our customer support team.</p>
                  </td>
                </tr>
              </table>

            </td>
          </tr>

          <!-- Closing -->
          <tr>
            <td align="center" style="padding: 20px 30px 30px;">
              <p style="margin: 0; color: #666666; font-size: 14px;">We hope to serve you again soon!</p>
              <p style="margin: 8px 0 0; color: #999999; font-size: 13px;">Thank you for considering {{app_name}}</p>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td align="center" style="padding: 20px 30px; background-color: #fafafa; border-top: 1px solid #f0f0f0;">
              <p style="margin: 0 0 8px; font-size: 12px; color: #999999;">{{footer}}</p>
              <p style="margin: 0; font-size: 12px; color: #999999;">This is an automated message. Please do not reply.</p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
