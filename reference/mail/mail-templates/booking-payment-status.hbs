<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="x-ua-compatible" content="ie=edge" />
    <title>{{emailTitle}}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
  </head>
  <body style="margin: 0; padding: 0; background-color: #f3f4f6; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">
    <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="background-color: #f3f4f6; padding: 24px 0;">
      <tr>
        <td align="center">
          <table role="presentation" cellpadding="0" cellspacing="0" width="680" style="max-width: 680px; width: 100%; background-color: #ffffff; border-radius: 12px; overflow: hidden;">
            <tr>
              <td style="padding: 22px 24px 10px; text-align: center;">
                <img src="{{logo_url}}" alt="{{app_name}}" width="140" style="display: inline-block; border: 0;" />
              </td>
            </tr>
            <tr>
              <td style="padding: 8px 24px 24px; text-align: center; border-bottom: 1px solid #ececec;">
                <h2 style="margin: 0; color: #1f2937; font-size: 24px; font-weight: 700; line-height: 1.25;">{{emailTitle}}</h2>
                <p style="margin: 10px 0 0; color: #6b7280; font-size: 16px; line-height: 1.4;">{{emailIntro}}</p>
              </td>
            </tr>
            <tr>
              <td style="padding: 24px;">
                <p style="margin: 0 0 18px; color: #1f2937; font-size: 18px; line-height: 1.4;">Hi {{recipientName}},</p>

                <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="border-collapse: collapse; margin-bottom: 20px; background-color: #f8fafc; border: 1px solid #e5e7eb; border-radius: 10px;">
                  <tr>
                    <td style="padding: 14px 16px; color: #111827; font-weight: 700; font-size: 14px;">
                      Booking Summary
                      {{#if isMerchantRecipient}}
                      <span style="font-weight: 500; color: #6b7280;">(Approver View)</span>
                      {{/if}}
                    </td>
                  </tr>
                  <tr>
                    <td style="padding: 0 16px 14px;">
                      <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="border-collapse: collapse;">
                        <tr>
                          <td style="padding: 7px 0; color: #6b7280; font-size: 13px;">Booking Reference</td>
                          <td align="right" style="padding: 7px 0; color: #111827; font-size: 13px; font-weight: 600;">{{bookingReferenceDisplay}}</td>
                        </tr>
                        <tr>
                          <td style="padding: 7px 0; color: #6b7280; font-size: 13px;">Booking Status</td>
                          <td align="right" style="padding: 7px 0;">
                            <span style="{{bookingStatusBadgeStyle}}">{{bookingStatusLabel}}</span>
                          </td>
                        </tr>
                        <tr>
                          <td style="padding: 7px 0; color: #6b7280; font-size: 13px;">Payment Status</td>
                          <td align="right" style="padding: 7px 0;">
                            <span style="{{paymentStatusBadgeStyle}}">{{paymentStatusLabel}}</span>
                          </td>
                        </tr>
                        {{#unless isGeneralBooking}}
                        <tr>
                          <td style="padding: 7px 0; color: #6b7280; font-size: 13px;">Slot Count</td>
                          <td align="right" style="padding: 7px 0; color: #111827; font-size: 13px; font-weight: 600;">{{slotCount}}</td>
                        </tr>
                        {{/unless}}
                        <tr>
                          <td style="padding: 7px 0; color: #6b7280; font-size: 13px; vertical-align: top;">Timeslot and Selected Service</td>
                          <td align="right" style="padding: 7px 0; color: #111827; font-size: 13px; font-weight: 600; line-height: 1.5;">{{selectedCourtsAndTimeslotSummary}}</td>
                        </tr>
                        {{#unless isGeneralBooking}}
                        <tr>
                          <td style="padding: 7px 0; color: #6b7280; font-size: 13px;">Timezone</td>
                          <td align="right" style="padding: 7px 0; color: #111827; font-size: 13px; font-weight: 600;">{{timezoneLabel}}</td>
                        </tr>
                        {{/unless}}
                      </table>
                    </td>
                  </tr>
                </table>

                {{#if hasGeneralPricingBreakdown}}
                <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="border-collapse: collapse; margin-bottom: 20px;">
                  <tr>
                    <td style="padding: 0 0 10px; color: #9ca3af; font-weight: 700; font-size: 13px; letter-spacing: 1.5px; text-transform: uppercase;">Price Breakdown</td>
                  </tr>
                  <tr>
                    <td style="border-top: 1px solid #e5e7eb; padding-top: 12px;">
                      <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="border-collapse: collapse;">
                        <tr>
                          <td style="padding: 8px 0; color: #111827; font-size: 14px; font-weight: 600;">Service</td>
                          <td align="right" style="padding: 8px 0; color: #111827; font-size: 14px; font-weight: 600;"></td>
                        </tr>
                        <tr>
                          <td style="padding: 4px 0 4px 16px; color: #6b7280; font-size: 13px;">{{serviceTitle}}</td>
                          <td align="right" style="padding: 4px 0; color: #6b7280; font-size: 13px;">{{currency}} {{serviceAmount}}</td>
                        </tr>
                        <tr>
                          <td style="padding: 8px 0; color: #111827; font-size: 14px; font-weight: 600;">Add-ons</td>
                          {{#if hasAddOns}}
                          <td align="right" style="padding: 8px 0; color: #111827; font-size: 14px; font-weight: 600;"></td>
                          {{else}}
                          <td align="right" style="padding: 8px 0; color: #111827; font-size: 14px; font-weight: 600;">{{currency}} {{addOnsTotal}}</td>
                          {{/if}}
                        </tr>
                        {{#if hasAddOns}}
                        {{#each addOns}}
                        <tr>
                          <td style="padding: 4px 0 4px 16px; color: #6b7280; font-size: 13px;">{{name}}</td>
                          <td align="right" style="padding: 4px 0; color: #6b7280; font-size: 13px;">{{../currency}} {{amount}}</td>
                        </tr>
                        {{/each}}
                        {{/if}}
                        <tr>
                          <td style="padding: 8px 0; color: #111827; font-size: 14px; font-weight: 600;">Options</td>
                          {{#if hasOptions}}
                          <td align="right" style="padding: 8px 0; color: #111827; font-size: 14px; font-weight: 600;"></td>
                          {{else}}
                          <td align="right" style="padding: 8px 0; color: #111827; font-size: 14px; font-weight: 600;">{{currency}} {{optionsTotal}}</td>
                          {{/if}}
                        </tr>
                        {{#if hasOptions}}
                        {{#each options}}
                        <tr>
                          <td style="padding: 4px 0 4px 16px; color: #6b7280; font-size: 13px;">{{label}}</td>
                          <td align="right" style="padding: 4px 0; color: #6b7280; font-size: 13px;">{{#if isPositive}}+{{/if}}{{../currency}} {{adjustment}}</td>
                        </tr>
                        {{/each}}
                        {{/if}}
                        {{#if hasVouchersApplied}}
                        <tr>
                          <td style="padding: 8px 0; color: #111827; font-size: 14px; font-weight: 600;">Vouchers</td>
                          <td align="right" style="padding: 8px 0; color: #111827; font-size: 14px; font-weight: 600;"></td>
                        </tr>
                        {{#each vouchersApplied}}
                        <tr>
                          <td style="padding: 4px 0 4px 16px; color: #6b7280; font-size: 13px;">Voucher ({{voucher_code}})</td>
                          <td align="right" style="padding: 4px 0; color: #6b7280; font-size: 13px;">-{{../currency}} {{voucher_discount}}</td>
                        </tr>
                        {{/each}}
                        {{/if}}
                        <tr>
                          <td colspan="2" style="border-top: 1px solid #e5e7eb; padding-top: 4px;"></td>
                        </tr>
                        <tr>
                          <td style="padding: 8px 0; color: #111827; font-size: 15px; font-weight: 700;">Total</td>
                          <td align="right" style="padding: 8px 0; color: #16a34a; font-size: 16px; font-weight: 700;">{{currency}} {{amount}}</td>
                        </tr>
                      </table>
                    </td>
                  </tr>
                </table>
                {{else}}
                {{#if hasVouchersApplied}}
                <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="border-collapse: collapse; margin-bottom: 20px;">
                  <tr>
                    <td style="padding: 0 0 10px; color: #9ca3af; font-weight: 700; font-size: 13px; letter-spacing: 1.5px; text-transform: uppercase;">Vouchers Applied</td>
                  </tr>
                  <tr>
                    <td style="border-top: 1px solid #e5e7eb; padding-top: 12px;">
                      <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="border-collapse: collapse;">
                        <tr>
                          <td style="padding: 8px 0; color: #6b7280; font-size: 14px;">Subtotal</td>
                          <td align="right" style="padding: 8px 0; color: #111827; font-size: 14px; font-weight: 600;">{{currency}} {{orderSubtotal}}</td>
                        </tr>
                        {{#each vouchersApplied}}
                        <tr>
                          <td style="padding: 8px 0; color: #6b7280; font-size: 14px;">Voucher: {{voucher_code}}</td>
                          <td align="right" style="padding: 8px 0; color: #16a34a; font-size: 14px; font-weight: 600;">- {{../currency}} {{voucher_discount}}</td>
                        </tr>
                        {{/each}}
                        <tr>
                          <td colspan="2" style="border-top: 1px solid #e5e7eb;"></td>
                        </tr>
                        <tr>
                          <td style="padding: 8px 0; color: #6b7280; font-size: 14px; font-weight: 700;">Total After Discount</td>
                          <td align="right" style="padding: 8px 0; color: #2563eb; font-size: 16px; font-weight: 700;">{{currency}} {{orderTotalAmount}}</td>
                        </tr>
                      </table>
                    </td>
                  </tr>
                </table>
                {{/if}}
                {{/if}}

                <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="border-collapse: collapse; margin-bottom: 20px;">
                  <tr>
                    <td style="padding: 0 0 10px; color: #9ca3af; font-weight: 700; font-size: 13px; letter-spacing: 1.5px; text-transform: uppercase;">Payment Details</td>
                  </tr>
                  <tr>
                    <td style="border-top: 1px solid #e5e7eb; padding-top: 12px;">
                      <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="border-collapse: collapse;">
                        {{#unless isFullyCovered}}
                        <tr>
                          <td style="padding: 8px 0; color: #6b7280; font-size: 14px;">Payment Reference</td>
                          <td align="right" style="padding: 8px 0; color: #111827; font-size: 14px; font-weight: 600;">{{paymentReference}}</td>
                        </tr>
                        <tr>
                          <td style="padding: 8px 0; color: #6b7280; font-size: 14px;">Payment Notified At</td>
                          <td align="right" style="padding: 8px 0; color: #111827; font-size: 14px; font-weight: 600;">{{paymentNotifiedAt}}</td>
                        </tr>
                        {{/unless}}
                        {{#if isFullyCovered}}
                        <tr>
                          <td style="padding: 8px 0; color: #6b7280; font-size: 14px;">Payment Method</td>
                          <td align="right" style="padding: 8px 0; color: #166534; font-size: 14px; font-weight: 600;">Covered by Voucher</td>
                        </tr>
                        {{/if}}
                        <tr>
                          <td style="padding: 8px 0; color: #6b7280; font-size: 14px;">Amount</td>
                          <td align="right" style="padding: 8px 0; color: #2563eb; font-size: 16px; font-weight: 700;">{{currency}} {{amount}}</td>
                        </tr>
                      </table>
                    </td>
                  </tr>
                </table>

                <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="border-collapse: collapse;">
                  <tr>
                    <td style="padding: 0 0 10px; color: #9ca3af; font-weight: 700; font-size: 13px; letter-spacing: 1.5px; text-transform: uppercase;">Booking Details</td>
                  </tr>
                  <tr>
                    <td style="border-top: 1px solid #e5e7eb; padding-top: 12px;">
                      <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="border-collapse: collapse;">
                        <tr>
                          <td style="padding: 8px 0; color: #6b7280; font-size: 14px;">Merchant</td>
                          <td align="right" style="padding: 8px 0; color: #111827; font-size: 14px; font-weight: 600;">{{sellerName}}</td>
                        </tr>
                        <tr>
                          <td style="padding: 8px 0; color: #6b7280; font-size: 14px;">Service Date</td>
                          <td align="right" style="padding: 8px 0; color: #111827; font-size: 14px; font-weight: 600;">{{scheduledDate}}</td>
                        </tr>
                        <tr>
                          <td style="padding: 8px 0; color: #6b7280; font-size: 14px;">Service Time</td>
                          <td align="right" style="padding: 8px 0; color: #111827; font-size: 14px; font-weight: 600;">{{scheduledStartTime}} - {{scheduledEndTime}}</td>
                        </tr>
                        <tr>
                          <td style="padding: 8px 0; color: #6b7280; font-size: 14px;">Customer Name</td>
                          <td align="right" style="padding: 8px 0; color: #111827; font-size: 14px; font-weight: 600;">{{primaryGuestName}}</td>
                        </tr>
                        <tr>
                          <td style="padding: 8px 0; color: #6b7280; font-size: 14px;">Customer Email</td>
                          <td align="right" style="padding: 8px 0; color: #111827; font-size: 14px; font-weight: 600;">{{primaryGuestEmail}}</td>
                        </tr>
                        <tr>
                          <td style="padding: 8px 0; color: #6b7280; font-size: 14px;">Customer Number</td>
                          <td align="right" style="padding: 8px 0; color: #111827; font-size: 14px; font-weight: 600;">{{primaryGuestPhone}}</td>
                        </tr>
                        {{#if additionalGuestNames}}
                        <tr>
                          <td style="padding: 8px 0; color: #6b7280; font-size: 14px; vertical-align: top;">Additional Guests</td>
                          <td align="right" style="padding: 8px 0; color: #111827; font-size: 14px; font-weight: 600; line-height: 1.5;">
                            {{#each additionalGuestNames}}
                            <div>{{this}}</div>
                            {{/each}}
                          </td>
                        </tr>
                        {{/if}}
                        {{#if rejectionReason}}
                        <tr>
                          <td style="padding: 8px 0; color: #6b7280; font-size: 14px;">Rejection Reason</td>
                          <td align="right" style="padding: 8px 0; color: #111827; font-size: 14px; font-weight: 700;">{{rejectionReason}}</td>
                        </tr>
                        {{/if}}
                      </table>
                    </td>
                  </tr>
                </table>

                {{#if hasMultipleSlotDetails}}
                <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="border-collapse: collapse; margin-top: 20px;">
                  <tr>
                    <td style="padding: 0 0 10px; color: #9ca3af; font-weight: 700; font-size: 13px; letter-spacing: 1.5px; text-transform: uppercase;">Booked Slots</td>
                  </tr>
                  <tr>
                    <td style="border-top: 1px solid #e5e7eb; padding-top: 12px;">
                      {{#each slotDetails}}
                        <div style="padding: 10px 12px; border: 1px solid #e5e7eb; border-radius: 8px; margin-bottom: 8px;">
                          <div style="color: #111827; font-size: 13px; font-weight: 700;">{{bookingNumber}} • {{serviceTitle}}</div>
                          <div style="color: #4b5563; font-size: 13px; margin-top: 4px;">{{scheduledDate}} | {{scheduledStartTime}} - {{scheduledEndTime}}</div>
                          <div style="margin-top: 6px;">
                            <span style="{{statusBadgeStyle}}">{{status}}</span>
                          </div>
                        </div>
                      {{/each}}
                    </td>
                  </tr>
                </table>
                {{/if}}

                {{#if requiresAction}}
                <div style="margin-top: 20px; padding: 12px 14px; border: 1px solid #fed7aa; background: #fff7ed; border-radius: 8px;">
                  <div style="font-size: 13px; font-weight: 700; color: #9a3412;">Action Required</div>
                  <div style="margin-top: 4px; color: #9a3412; font-size: 13px; line-height: 1.5;">
                    Review payment proof, verify customer details, and confirm or reject the booking request.
                  </div>
                </div>
                {{/if}}

                {{#if showActionButton}}
                <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="margin-top: 24px;">
                  <tr>
                    <td align="center">
                      <a href="{{domain}}{{actionUrl}}" style="display: inline-block; background: #2563eb; color: #ffffff; text-decoration: none; font-weight: 600; font-size: 16px; padding: 12px 22px; border-radius: 8px;">{{ctaLabel}}</a>
                    </td>
                  </tr>
                </table>
                {{/if}}

                {{#if isCustomerRecipient}}
                <div style="margin: 20px 0 0; padding: 14px 16px; background-color: #f8fafc; border: 1px solid #e5e7eb; border-radius: 8px;">
                  <p style="margin: 0 0 6px; color: #111827; font-size: 14px; font-weight: 700;">Need Help?</p>
                  <p style="margin: 0 0 4px; color: #6b7280; font-size: 13px;">Contact {{sellerName}} directly:</p>
                  {{#if sellerContact}}
                  <p style="margin: 4px 0 0; color: #374151; font-size: 13px;">Phone: {{sellerContact}}</p>
                  {{/if}}
                  {{#if sellerEmail}}
                  <p style="margin: 4px 0 0; color: #374151; font-size: 13px;">Email: {{sellerEmail}}</p>
                  {{/if}}
                  {{#unless sellerContact}}{{#unless sellerEmail}}
                  <p style="margin: 4px 0 0; color: #6b7280; font-size: 13px;">Visit your merchant profile for help channels.</p>
                  {{/unless}}{{/unless}}
                </div>
                {{/if}}
              </td>
            </tr>
            <tr>
              <td style="padding: 22px 24px; color: #9ca3af; font-size: 14px; text-align: center; border-top: 1px solid #efefef;">
                <div>{{footer}}</div>
                <div style="margin-top: 6px;">This is an automated message. Please do not reply.</div>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
