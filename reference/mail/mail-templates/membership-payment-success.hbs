<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Membership Payment Confirmed - {{app_name}}</title>
  <!--[if mso]>
  <style type="text/css">
    table { border-collapse: collapse; }
    .wrapper { width: 100% !important; }
    .container { width: 480px !important; }
  </style>
  <![endif]-->
</head>
<body style="margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; line-height: 1.5; color: #1a1a1a; background-color: #f5f5f5; -webkit-font-smoothing: antialiased;">
  <!-- Wrapper -->
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #f5f5f5;">
    <tr>
      <td align="center" style="padding: 40px 20px;">
        <!-- Container -->
        <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="max-width: 480px; background-color: #ffffff; border-radius: 12px; overflow: hidden;">

          <!-- Logo -->
          {{#if logo_url}}
          <tr>
            <td align="center" style="padding: 30px 30px 0;">
              <img src="{{logo_url}}" alt="{{app_name}}" width="150" style="display: block; max-width: 150px; height: auto;">
            </td>
          </tr>
          {{/if}}

          <!-- Header with Icon -->
          <tr>
            <td align="center" style="padding: 30px 30px 30px; border-bottom: 1px solid #f0f0f0;">
              <!-- Icon Circle -->
              <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td align="center" style="width: 64px; height: 64px; background-color: #e0f2fe; border-radius: 50%;">
                    <img src="https://img.icons8.com/ios-filled/50/3b82f6/ok.png" alt="Success" width="32" height="32" style="display: block;">
                  </td>
                </tr>
              </table>
              <h1 style="margin: 20px 0 8px; font-size: 24px; font-weight: 600; color: #1a1a1a;">Membership Activated</h1>
              <p style="margin: 0; color: #666666; font-size: 15px;">Your membership payment has been confirmed</p>
            </td>
          </tr>

          <!-- Content -->
          <tr>
            <td style="padding: 30px;">
              <!-- Greeting -->
              <p style="margin: 0 0 8px; font-size: 18px; color: #1a1a1a;">Hi {{userName}},</p>
              <p style="margin: 0 0 30px; color: #666666; font-size: 15px; line-height: 1.6;">{{body}}</p>

              <!-- Payment Details Section -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 30px;">
                <tr>
                  <td style="padding-bottom: 12px; border-bottom: 1px solid #f0f0f0;">
                    <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td style="padding-right: 10px; vertical-align: middle;">
                          <img src="https://img.icons8.com/ios-filled/20/999999/bank-card-back-side.png" alt="" width="20" height="20">
                        </td>
                        <td style="font-size: 13px; font-weight: 600; color: #999999; text-transform: uppercase; letter-spacing: 0.5px;">
                          Membership Details
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
                <tr>
                  <td style="padding-top: 16px;">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td style="padding: 6px 0; font-size: 14px; color: #666666;">Membership ID</td>
                        <td align="right" style="padding: 6px 0; font-size: 14px; font-weight: 600; color: #1a1a1a;">{{entityId}}</td>
                      </tr>
                      {{#if amount}}
                      <tr>
                        <td style="padding: 6px 0; font-size: 14px; color: #666666;">Amount Paid</td>
                        <td align="right" style="padding: 6px 0; font-size: 18px; font-weight: 600; color: #3b82f6;">{{amount}}</td>
                      </tr>
                      {{/if}}
                    </table>
                  </td>
                </tr>
              </table>

              <!-- What Happens Next Section -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 30px;">
                <tr>
                  <td style="padding-bottom: 12px; border-bottom: 1px solid #f0f0f0;">
                    <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td style="padding-right: 10px; vertical-align: middle;">
                          <img src="https://img.icons8.com/ios-filled/20/999999/info.png" alt="" width="20" height="20">
                        </td>
                        <td style="font-size: 13px; font-weight: 600; color: #999999; text-transform: uppercase; letter-spacing: 0.5px;">
                          What Happens Next
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
                <tr>
                  <td style="padding-top: 16px;">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td style="padding: 8px 0; font-size: 14px; color: #666666; line-height: 1.5;">
                          <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                            <tr>
                              <td style="padding-right: 12px; vertical-align: top; color: #3b82f6; font-weight: 600;">1.</td>
                              <td style="color: #666666;">Your membership is now active and benefits are available</td>
                            </tr>
                          </table>
                        </td>
                      </tr>
                      <tr>
                        <td style="padding: 8px 0; font-size: 14px; color: #666666; line-height: 1.5;">
                          <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                            <tr>
                              <td style="padding-right: 12px; vertical-align: top; color: #3b82f6; font-weight: 600;">2.</td>
                              <td style="color: #666666;">You can view your membership details in your account</td>
                            </tr>
                          </table>
                        </td>
                      </tr>
                      <tr>
                        <td style="padding: 8px 0; font-size: 14px; color: #666666; line-height: 1.5;">
                          <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                            <tr>
                              <td style="padding-right: 12px; vertical-align: top; color: #3b82f6; font-weight: 600;">3.</td>
                              <td style="color: #666666;">Keep this email as your payment confirmation</td>
                            </tr>
                          </table>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>

              <!-- CTA Button -->
              {{#if actionUrl}}
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 20px;">
                <tr>
                  <td align="center">
                    <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td align="center" style="background-color: #3b82f6; border-radius: 8px;">
                          <a href="{{domain}}{{actionUrl}}" style="display: inline-block; padding: 14px 28px; font-size: 14px; font-weight: 600; color: #ffffff; text-decoration: none;">View Membership</a>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>
              {{/if}}

            </td>
          </tr>

          <!-- Closing -->
          <tr>
            <td align="center" style="padding: 20px 30px 30px;">
              <p style="margin: 0; color: #666666; font-size: 14px;">Thank you for your membership!</p>
              <p style="margin: 8px 0 0; color: #999999; font-size: 13px;">We appreciate your support for {{app_name}}</p>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td align="center" style="padding: 20px 30px; background-color: #fafafa; border-top: 1px solid #f0f0f0;">
              <p style="margin: 0 0 8px; font-size: 12px; color: #999999;">{{footer}}</p>
              <p style="margin: 0; font-size: 12px; color: #999999;">This is an automated message. Please do not reply.</p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
