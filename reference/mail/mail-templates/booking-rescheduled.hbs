<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="x-ua-compatible" content="ie=edge" />
    <title>Booking Rescheduled</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
  </head>
  <body style="margin: 0; padding: 0; background-color: #f3f4f6; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">
    <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="background-color: #f3f4f6; padding: 24px 0;">
      <tr>
        <td align="center">
          <table role="presentation" cellpadding="0" cellspacing="0" width="680" style="max-width: 680px; width: 100%; background-color: #ffffff; border-radius: 12px; overflow: hidden;">
            <tr>
              <td style="padding: 22px 24px 10px; text-align: center;">
                <img src="{{logo_url}}" alt="{{app_name}}" width="140" style="display: inline-block; border: 0;" />
              </td>
            </tr>
            <tr>
              <td style="padding: 8px 24px 24px; text-align: center; border-bottom: 1px solid #ececec;">
                <h2 style="margin: 0; color: #1f2937; font-size: 24px; font-weight: 700; line-height: 1.25;">Booking Rescheduled</h2>
                <p style="margin: 10px 0 0; color: #6b7280; font-size: 16px; line-height: 1.4;">
                  Booking {{bookingNumber}} has an updated schedule.
                </p>
              </td>
            </tr>
            <tr>
              <td style="padding: 24px;">
                <p style="margin: 0 0 18px; color: #1f2937; font-size: 18px; line-height: 1.4;">Hi {{recipientName}},</p>

                <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="border-collapse: collapse; margin-bottom: 20px; background-color: #f8fafc; border: 1px solid #e5e7eb; border-radius: 10px;">
                  <tr>
                    <td style="padding: 14px 16px; color: #111827; font-weight: 700; font-size: 14px;">
                      Reschedule Summary
                      {{#if isMerchantRecipient}}
                      <span style="font-weight: 500; color: #6b7280;">(Approver View)</span>
                      {{/if}}
                    </td>
                  </tr>
                  <tr>
                    <td style="padding: 0 16px 14px;">
                      <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="border-collapse: collapse;">
                        <tr>
                          <td style="padding: 7px 0; color: #6b7280; font-size: 13px;">Booking Number</td>
                          <td align="right" style="padding: 7px 0; color: #111827; font-size: 13px; font-weight: 600;">{{bookingNumber}}</td>
                        </tr>
                        <tr>
                          <td style="padding: 7px 0; color: #6b7280; font-size: 13px;">Service</td>
                          <td align="right" style="padding: 7px 0; color: #111827; font-size: 13px; font-weight: 600;">{{serviceTitle}}</td>
                        </tr>
                        <tr>
                          <td style="padding: 7px 0; color: #6b7280; font-size: 13px;">Merchant</td>
                          <td align="right" style="padding: 7px 0; color: #111827; font-size: 13px; font-weight: 600;">{{sellerName}}</td>
                        </tr>
                        <tr>
                          <td style="padding: 7px 0; color: #6b7280; font-size: 13px;">Customer</td>
                          <td align="right" style="padding: 7px 0; color: #111827; font-size: 13px; font-weight: 600;">{{customerName}}</td>
                        </tr>
                        <tr>
                          <td style="padding: 7px 0; color: #6b7280; font-size: 13px;">Customer Email</td>
                          <td align="right" style="padding: 7px 0; color: #111827; font-size: 13px; font-weight: 600;">{{customerEmail}}</td>
                        </tr>
                        <tr>
                          <td style="padding: 7px 0; color: #6b7280; font-size: 13px;">Guests</td>
                          <td align="right" style="padding: 7px 0; color: #111827; font-size: 13px; font-weight: 600;">{{guestCount}}</td>
                        </tr>
                        <tr>
                          <td style="padding: 7px 0; color: #6b7280; font-size: 13px;">Rescheduled By</td>
                          <td align="right" style="padding: 7px 0; color: #111827; font-size: 13px; font-weight: 600;">{{actorName}} ({{actorRole}})</td>
                        </tr>
                        <tr>
                          <td style="padding: 7px 0; color: #6b7280; font-size: 13px;">Timezone</td>
                          <td align="right" style="padding: 7px 0; color: #111827; font-size: 13px; font-weight: 600;">{{timezoneLabel}}</td>
                        </tr>
                      </table>
                    </td>
                  </tr>
                </table>

                <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="border-collapse: collapse; margin-bottom: 16px;">
                  <tr>
                    <td style="padding: 0 0 10px; color: #9ca3af; font-weight: 700; font-size: 13px; letter-spacing: 1.5px; text-transform: uppercase;">Previous Schedule</td>
                  </tr>
                  <tr>
                    <td style="border-top: 1px solid #e5e7eb; padding-top: 12px;">
                      <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="border-collapse: collapse;">
                        <tr>
                          <td style="padding: 8px 0; color: #6b7280; font-size: 14px;">Date</td>
                          <td align="right" style="padding: 8px 0; color: #111827; font-size: 14px; font-weight: 600;">{{oldScheduledDate}}</td>
                        </tr>
                        <tr>
                          <td style="padding: 8px 0; color: #6b7280; font-size: 14px;">Time</td>
                          <td align="right" style="padding: 8px 0; color: #111827; font-size: 14px; font-weight: 600;">{{oldScheduledStartTime}} - {{oldScheduledEndTime}}</td>
                        </tr>
                      </table>
                    </td>
                  </tr>
                </table>

                <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="border-collapse: collapse;">
                  <tr>
                    <td style="padding: 0 0 10px; color: #9ca3af; font-weight: 700; font-size: 13px; letter-spacing: 1.5px; text-transform: uppercase;">New Schedule</td>
                  </tr>
                  <tr>
                    <td style="border-top: 1px solid #e5e7eb; padding-top: 12px;">
                      <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="border-collapse: collapse;">
                        <tr>
                          <td style="padding: 8px 0; color: #6b7280; font-size: 14px;">Date</td>
                          <td align="right" style="padding: 8px 0; color: #111827; font-size: 14px; font-weight: 600;">{{newScheduledDate}}</td>
                        </tr>
                        <tr>
                          <td style="padding: 8px 0; color: #6b7280; font-size: 14px;">Time</td>
                          <td align="right" style="padding: 8px 0; color: #111827; font-size: 14px; font-weight: 600;">{{newScheduledStartTime}} - {{newScheduledEndTime}}</td>
                        </tr>
                        {{#if reason}}
                        <tr>
                          <td style="padding: 8px 0; color: #6b7280; font-size: 14px;">Reason</td>
                          <td align="right" style="padding: 8px 0; color: #111827; font-size: 14px; font-weight: 700;">{{reason}}</td>
                        </tr>
                        {{/if}}
                      </table>
                    </td>
                  </tr>
                </table>

                {{#if actionUrl}}
                <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="margin-top: 24px;">
                  <tr>
                    <td align="center">
                      <a href="{{domain}}{{actionUrl}}" style="display: inline-block; background: #2563eb; color: #ffffff; text-decoration: none; font-weight: 600; font-size: 16px; padding: 12px 22px; border-radius: 8px;">{{ctaLabel}}</a>
                    </td>
                  </tr>
                </table>
                {{/if}}

                <p style="margin: 16px 0 0; color: #6b7280; font-size: 14px; line-height: 1.6; text-align: center;">This is an automated update for your booking schedule.</p>
              </td>
            </tr>
            <tr>
              <td style="padding: 22px 24px; color: #9ca3af; font-size: 14px; text-align: center; border-top: 1px solid #efefef;">
                <div>{{footer}}</div>
                <div style="margin-top: 6px;">This is an automated message. Please do not reply.</div>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
