<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <title>Purchase Request Notification</title>
  </head>
  <body
    style='margin:0; padding:0; font-family: Arial, sans-serif; background-color:#f9f9f9; color:#333;'
  >
    <table
      width='100%'
      cellpadding='0'
      cellspacing='0'
      border='0'
      style='background-color: #f9f9f9; padding: 20px;'
    >
      <tr>
        <td align='center'>
          <table
            width='600'
            cellpadding='0'
            cellspacing='0'
            border='0'
            style='background-color:#ffffff; border-radius:8px; overflow:hidden; box-shadow:0 2px 5px rgba(0,0,0,0.1);'
          >
            <tr>
              <td align='center' style='background-color:#222; padding:20px;'>
                {{#if logo_url}}
                <img src="{{logo_url}}" alt="{{app_name}}" width="150" style="display: block; margin: 0 auto; max-width: 150px; height: auto;">
                {{else}}
                <h1 style='color:white; margin:0;'>Cody</h1>
                <p style='color:white; font-size:12px; margin:4px 0 0;'>Web
                  Development Inc</p>
                {{/if}}
              </td>
            </tr>
            <tr>
              <td style='padding: 30px;'>
                <p>{{salutation}},</p>
                <p>{{intro1}} </p>
                <p>{{intro2}}</p>
                <p><strong>PO Number:</strong> {{control_no}}</p>
                <p><strong>Amount:</strong>
                  {{moneyFormat purchaseOrderSummary.total}}</p>

                <p>{{closing}}</p>
                <p>{{signOff}}<br />Cody Team</p>
              </td>
            </tr>

            <tr>
              <td
                style='background-color:#f1f1f1; text-align:center; padding:20px;'
              >
                <div style='margin-bottom:10px;'>
                  <!-- Icons can be replaced with embedded base64 or hosted assets -->
                  <a href='#'><img
                      src='https://img.icons8.com/ios-filled/16/000000/facebook-new.png'
                    /></a>&nbsp;
                  <a href='#'><img
                      src='https://img.icons8.com/ios-filled/16/000000/linkedin.png'
                    /></a>&nbsp;
                  <a href='#'><img
                      src='https://img.icons8.com/ios-filled/16/000000/instagram-new.png'
                    /></a>&nbsp;
                  <a href='#'><img
                      src='https://img.icons8.com/ios-filled/16/000000/youtube-play.png'
                    /></a>&nbsp;
                  <a href='#'><img
                      src='https://img.icons8.com/ios-filled/16/000000/twitterx--v1.png'
                    /></a>
                </div>
                <p style='margin:4px 0;'><a
                    href='#'
                    style='color:#000; text-decoration:none;'
                  >Help Center</a>
                  |
                  <a href='#' style='color:#000; text-decoration:none;'>Contact
                    Us</a></p>
                <p style='font-size:12px; color:#555;'>
                  ©2025 Cody Inc. 2F ESY Bldg., corner Juana Osmena St. & Ma
                  Cristina St., Camputhaw, Cebu City, Philippines, 6000
                </p>
                <p style='font-size:11px; color:#999;'>This is an automatically
                  generated email from our subscription list. Please do not
                  reply to this email.</p>
              </td>
            </tr>

          </table>
        </td>
      </tr>
    </table>
  </body>
</html>