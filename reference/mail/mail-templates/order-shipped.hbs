<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Order Shipped - {{app_name}}</title>
  <!--[if mso]>
  <style type="text/css">
    table { border-collapse: collapse; }
    .wrapper { width: 100% !important; }
    .container { width: 480px !important; }
  </style>
  <![endif]-->
</head>
<body style="margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; line-height: 1.5; color: #1a1a1a; background-color: #f5f5f5; -webkit-font-smoothing: antialiased;">
  <!-- Wrapper -->
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #f5f5f5;">
    <tr>
      <td align="center" style="padding: 40px 20px;">
        <!-- Container -->
        <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="max-width: 480px; background-color: #ffffff; border-radius: 12px; overflow: hidden;">

          <!-- Logo -->
          {{#if logo_url}}
          <tr>
            <td align="center" style="padding: 30px 30px 0;">
              <img src="{{logo_url}}" alt="{{app_name}}" width="150" style="display: block; max-width: 150px; height: auto;">
            </td>
          </tr>
          {{/if}}

          <!-- Header with Icon -->
          <tr>
            <td align="center" style="padding: 30px 30px 30px; border-bottom: 1px solid #f0f0f0;">
              <!-- Icon Circle -->
              <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td align="center" style="width: 64px; height: 64px; background-color: #e0f2fe; border-radius: 50%;">
                    <img src="https://img.icons8.com/ios-filled/50/3b82f6/shipped.png" alt="Shipped" width="32" height="32" style="display: block;">
                  </td>
                </tr>
              </table>
              <h1 style="margin: 20px 0 8px; font-size: 24px; font-weight: 600; color: #1a1a1a;">Order Shipped</h1>
              <p style="margin: 0; color: #666666; font-size: 15px;">Your package is on its way!</p>
            </td>
          </tr>

          <!-- Content -->
          <tr>
            <td style="padding: 30px;">
              <!-- Greeting -->
              <p style="margin: 0 0 8px; font-size: 18px; color: #1a1a1a;">Hi {{userName}},</p>
              <p style="margin: 0 0 30px; color: #666666; font-size: 15px; line-height: 1.6;">{{body}}</p>

              <!-- Shipping Info Section -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 30px;">
                <tr>
                  <td style="padding-bottom: 12px; border-bottom: 1px solid #f0f0f0;">
                    <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td style="padding-right: 10px; vertical-align: middle;">
                          <img src="https://img.icons8.com/ios-filled/20/999999/in-transit.png" alt="" width="20" height="20">
                        </td>
                        <td style="font-size: 13px; font-weight: 600; color: #999999; text-transform: uppercase; letter-spacing: 0.5px;">
                          Shipping Information
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
                <tr>
                  <td style="padding-top: 16px;">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                      {{#if shipping_provider}}
                      <tr>
                        <td style="padding: 6px 0; font-size: 14px; color: #666666;">Carrier</td>
                        <td align="right" style="padding: 6px 0; font-size: 14px; font-weight: 600; color: #1a1a1a;">{{shipping_provider}}</td>
                      </tr>
                      {{/if}}
                      {{#if tracking_number}}
                      <tr>
                        <td style="padding: 6px 0; font-size: 14px; color: #666666;">Tracking Number</td>
                        <td align="right" style="padding: 6px 0; font-size: 14px; font-weight: 600; color: #3b82f6;">{{tracking_number}}</td>
                      </tr>
                      {{/if}}
                      {{#if estimated_delivery}}
                      <tr>
                        <td style="padding: 6px 0; font-size: 14px; color: #666666;">Estimated Delivery</td>
                        <td align="right" style="padding: 6px 0; font-size: 14px; font-weight: 600; color: #1a1a1a;">{{estimated_delivery}}</td>
                      </tr>
                      {{/if}}
                    </table>
                  </td>
                </tr>
              </table>

              <!-- Order Details Section -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 30px;">
                <tr>
                  <td style="padding-bottom: 12px; border-bottom: 1px solid #f0f0f0;">
                    <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td style="padding-right: 10px; vertical-align: middle;">
                          <img src="https://img.icons8.com/ios-filled/20/999999/document.png" alt="" width="20" height="20">
                        </td>
                        <td style="font-size: 13px; font-weight: 600; color: #999999; text-transform: uppercase; letter-spacing: 0.5px;">
                          Order Details
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
                <tr>
                  <td style="padding-top: 16px;">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td style="padding: 6px 0; font-size: 14px; color: #666666;">Order Number</td>
                        <td align="right" style="padding: 6px 0; font-size: 14px; font-weight: 600; color: #1a1a1a;">{{#if order_number}}{{order_number}}{{else}}#{{entityId}}{{/if}}</td>
                      </tr>
                      {{#if seller_name}}
                      <tr>
                        <td style="padding: 6px 0; font-size: 14px; color: #666666;">Seller</td>
                        <td align="right" style="padding: 6px 0; font-size: 14px; font-weight: 600; color: #1a1a1a;">{{seller_name}}</td>
                      </tr>
                      {{/if}}
                    </table>
                  </td>
                </tr>
              </table>

              <!-- Items Section -->
              {{#if order_items}}
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 30px;">
                <tr>
                  <td style="padding-bottom: 12px; border-bottom: 1px solid #f0f0f0;">
                    <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td style="padding-right: 10px; vertical-align: middle;">
                          <img src="https://img.icons8.com/ios-filled/20/999999/box.png" alt="" width="20" height="20">
                        </td>
                        <td style="font-size: 13px; font-weight: 600; color: #999999; text-transform: uppercase; letter-spacing: 0.5px;">
                          Items Shipped
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
                {{#each order_items}}
                <tr>
                  <td style="padding: 16px 0; border-bottom: 1px solid #f5f5f5;">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td width="56" valign="top" style="padding-right: 16px;">
                          {{#if image_url}}
                          <img src="{{image_url}}" alt="{{product_name}}" width="56" height="56" style="display: block; border-radius: 8px; background-color: #f5f5f5; object-fit: cover;">
                          {{else}}
                          <div style="width: 56px; height: 56px; background-color: #f5f5f5; border-radius: 8px;"></div>
                          {{/if}}
                        </td>
                        <td valign="top">
                          <p style="margin: 0 0 4px; font-size: 14px; font-weight: 500; color: #1a1a1a; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">{{product_name}}</p>
                          {{#if variant_name}}<p style="margin: 0; font-size: 13px; color: #999999;">{{variant_name}}</p>{{/if}}
                          <p style="margin: 2px 0 0; font-size: 13px; color: #666666;">Qty: {{quantity}}</p>
                        </td>
                        <td align="right" valign="top" style="white-space: nowrap; padding-left: 12px;">
                          <p style="margin: 0; font-size: 14px; font-weight: 600; color: #1a1a1a;">{{total_price}}</p>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
                {{/each}}

                <!-- Totals -->
                <tr>
                  <td style="padding-top: 20px;">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #fafafa; border-radius: 8px; padding: 16px;">
                      <tr>
                        <td style="padding: 16px;">
                          {{#if subtotal}}
                          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                            <tr>
                              <td style="padding: 8px 0; font-size: 14px; color: #666666;">Subtotal</td>
                              <td align="right" style="padding: 8px 0; font-size: 14px; color: #1a1a1a;">{{subtotal}}</td>
                            </tr>
                          </table>
                          {{/if}}
                          {{#if shipping_amount}}
                          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                            <tr>
                              <td style="padding: 8px 0; font-size: 14px; color: #666666;">Shipping</td>
                              <td align="right" style="padding: 8px 0; font-size: 14px; color: #1a1a1a;">{{shipping_amount}}</td>
                            </tr>
                          </table>
                          {{/if}}
                          {{#if tax_amount}}
                          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                            <tr>
                              <td style="padding: 8px 0; font-size: 14px; color: #666666;">Tax</td>
                              <td align="right" style="padding: 8px 0; font-size: 14px; color: #1a1a1a;">{{tax_amount}}</td>
                            </tr>
                          </table>
                          {{/if}}
                          {{#if discount_amount}}
                          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                            <tr>
                              <td style="padding: 8px 0; font-size: 14px; color: #666666;">Discount</td>
                              <td align="right" style="padding: 8px 0; font-size: 14px; color: #1a1a1a;">-{{discount_amount}}</td>
                            </tr>
                          </table>
                          {{/if}}
                          {{#if amount}}
                          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="border-top: 1px solid #e0e0e0; margin-top: 8px;">
                            <tr>
                              <td style="padding: 16px 0 0; font-size: 16px; font-weight: 600; color: #1a1a1a;">Order Total</td>
                              <td align="right" style="padding: 16px 0 0; font-size: 16px; font-weight: 600; color: #3b82f6;">{{amount}}</td>
                            </tr>
                          </table>
                          {{/if}}
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>
              {{/if}}

              <!-- Shipping Address -->
              {{#if shipping_address}}
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 30px;">
                <tr>
                  <td style="padding-bottom: 12px; border-bottom: 1px solid #f0f0f0;">
                    <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td style="padding-right: 10px; vertical-align: middle;">
                          <img src="https://img.icons8.com/ios-filled/20/999999/marker.png" alt="" width="20" height="20">
                        </td>
                        <td style="font-size: 13px; font-weight: 600; color: #999999; text-transform: uppercase; letter-spacing: 0.5px;">
                          Shipping To
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
                <tr>
                  <td style="padding-top: 16px;">
                    <p style="margin: 0; font-size: 14px; color: #666666; line-height: 1.6;">{{shipping_address}}</p>
                  </td>
                </tr>
              </table>
              {{/if}}

            </td>
          </tr>

          <!-- Closing -->
          <tr>
            <td align="center" style="padding: 20px 30px 30px;">
              <p style="margin: 0; color: #666666; font-size: 14px;">Your package is on its way to you!</p>
              <p style="margin: 8px 0 0; color: #999999; font-size: 13px;">Thank you for shopping with {{app_name}}</p>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td align="center" style="padding: 20px 30px; background-color: #fafafa; border-top: 1px solid #f0f0f0;">
              <p style="margin: 0 0 8px; font-size: 12px; color: #999999;">{{footer}}</p>
              <p style="margin: 0; font-size: 12px; color: #999999;">This is an automated message. Please do not reply.</p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
