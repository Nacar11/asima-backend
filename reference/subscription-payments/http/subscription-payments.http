### Subscription Payments API Tests
### Base URL
@baseUrl = http://localhost:4080/api/v1

### Login to get token
# @name login
POST {{baseUrl}}/auth/email/login
Content-Type: application/json

{
  "email": "admin@cody.inc",
  "password": "password"
}

### Set token from login response
@token = {{login.response.body.token}}

### ==================================================
### SUBSCRIPTION PAYMENTS ENDPOINTS
### ==================================================

### Create Subscription Payment
# @name createPayment
POST {{baseUrl}}/subscription-payments
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "subscription_id": 1,
  "amount": 499.00,
  "billing_cycle_start": "2025-12-12",
  "billing_cycle_end": "2026-01-12",
  "due_date": "2025-12-19",
  "payment_method": "gcash"
}

### Get All Subscription Payments (with pagination)
GET {{baseUrl}}/subscription-payments?page=1&limit=10
Authorization: Bearer {{token}}

### Get Payments for a Subscription
@subscriptionId = 1
GET {{baseUrl}}/subscription-payments/subscription/{{subscriptionId}}
Authorization: Bearer {{token}}

### Get Payment by ID
@paymentId = {{createPayment.response.body.id}}
GET {{baseUrl}}/subscription-payments/{{paymentId}}
Authorization: Bearer {{token}}

### Process Payment (mark as paid)
POST {{baseUrl}}/subscription-payments/{{paymentId}}/process
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "transaction_id": "pi_1234567890abcdef",
  "payment_method": "gcash"
}

### Mark Payment as Failed
POST {{baseUrl}}/subscription-payments/{{paymentId}}/fail
Authorization: Bearer {{token}}

### Refund Payment
POST {{baseUrl}}/subscription-payments/{{paymentId}}/refund
Authorization: Bearer {{token}}

### Delete Payment
DELETE {{baseUrl}}/subscription-payments/{{paymentId}}
Authorization: Bearer {{token}}



