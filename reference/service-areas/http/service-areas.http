# @name login
POST {{baseUrl}}/api/v1/auth/email/login
accept: application/json
Content-Type: application/json

{
  "email": "{{adminEmail}}",
  "password": "{{adminPassword}}"
}

###
# @name createServiceCategory
POST {{baseUrl}}/api/v1/service-categories
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "name": "Areas Cat {{timestamp}}",
  "slug": "areas-cat-{{timestamp}}",
  "description": "Category for service areas"
}

###
# @name createService
POST {{baseUrl}}/api/v1/services
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "seller_id": 1,
  "category_id": "{{createServiceCategory.response.body.id}}",
  "title": "Area Service {{timestamp}}",
  "slug": "area-service-{{timestamp}}",
  "pricing_type": "fixed",
  "base_price": 800,
  "estimated_duration_minutes": 60,
  "service_radius_km": 15,
  "is_remote_available": false,
  "max_bookings_per_day": 8,
  "advance_booking_days": 30,
  "minimum_notice_hours": 12,
  "status": "draft",
  "is_featured": false,
  "requires_quote": false,
  "instant_booking": true
}

###
# @name createServiceArea
POST {{baseUrl}}/api/v1/service-areas
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "service_id": "{{createService.response.body.id}}",
  "city": "Quezon City",
  "province": "Metro Manila",
  "postal_code": "1100",
  "barangay": "Bagong Pag-asa",
  "additional_fee": 0,
  "additional_fee_type": "fixed",
  "minimum_order_amount": 500,
  "is_active": true
}

###
# @name listServiceAreas
GET {{baseUrl}}/api/v1/service-areas?take=10&skip=0
Authorization: Bearer {{login.response.body.token}}

###
# @name getServiceArea
GET {{baseUrl}}/api/v1/service-areas/{{createServiceArea.response.body.id}}
Authorization: Bearer {{login.response.body.token}}

###
# @name updateServiceArea
PATCH {{baseUrl}}/api/v1/service-areas/{{createServiceArea.response.body.id}}
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "is_active": false,
  "additional_fee": 150,
  "additional_fee_type": "per_km",
  "radius_km": 12
}

###
# @name deleteServiceArea
DELETE {{baseUrl}}/api/v1/service-areas/{{createServiceArea.response.body.id}}
Authorization: Bearer {{login.response.body.token}}




