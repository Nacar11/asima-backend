# @name login
POST {{baseUrl}}/api/v1/auth/email/login
accept: application/json
Content-Type: application/json

{
  "email": "{{adminEmail}}",
  "password": "{{adminPassword}}"
}

###
# @name createServiceCategory
POST {{baseUrl}}/api/v1/service-categories
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "name": "Home Cleaning {{timestamp}}",
  "code": "home-cleaning-{{timestamp}}",
  "description": "Home cleaning services"
}

###
# @name createService
POST {{baseUrl}}/api/v1/services
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "seller_id": 1,
  "category_id": "{{createServiceCategory.response.body.id}}",
  "title": "Aircon Cleaning {{timestamp}}",
  "code": "aircon-cleaning-{{timestamp}}",
  "pricing_type": "fixed",
  "base_price": 1500,
  "estimated_duration_minutes": 120,
  "service_radius_km": 10,
  "is_remote_available": false,
  "max_bookings_per_day": 5,
  "advance_booking_days": 30,
  "minimum_notice_hours": 24,
  "status": "draft",
  "is_featured": false,
  "requires_quote": false,
  "instant_booking": true
}

###
# @name listServices
GET {{baseUrl}}/api/v1/services?take=10&skip=0
Authorization: Bearer {{login.response.body.token}}

###
# @name listServicesWithSorting
GET {{baseUrl}}/api/v1/services?page=1&limit=40&sortField=created_at&sortBy=DESC
Authorization: Bearer {{login.response.body.token}}

###
# @name listServicesSortedByTitle
GET {{baseUrl}}/api/v1/services?page=1&limit=40&sortField=title&sortBy=ASC
Authorization: Bearer {{login.response.body.token}}

###
# @name listServicesSortedByPrice
GET {{baseUrl}}/api/v1/services?page=1&limit=40&sortField=base_price&sortBy=ASC
Authorization: Bearer {{login.response.body.token}}

###
# @name getService
GET {{baseUrl}}/api/v1/services/{{createService.response.body.id}}
Authorization: Bearer {{login.response.body.token}}

###
# @name updateService
PATCH {{baseUrl}}/api/v1/services/{{createService.response.body.id}}
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "status": "active",
  "is_featured": true,
  "requires_quote": false
}

###
# @name deleteService
DELETE {{baseUrl}}/api/v1/services/{{createService.response.body.id}}
Authorization: Bearer {{login.response.body.token}}

###
# @name serviceLookupCategories
GET {{baseUrl}}/api/v1/service-categories/lookup?searchValue=clean
Authorization: Bearer {{login.response.body.token}}

###
# @name serviceFeaturedCategories
GET {{baseUrl}}/api/v1/service-categories/featured?take=10
Authorization: Bearer {{login.response.body.token}}

###
# @name approveService
PATCH {{baseUrl}}/api/v1/services/{{createService.response.body.id}}/approve
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "reason": "Content approved"
}

###
# @name rejectService
PATCH {{baseUrl}}/api/v1/services/{{createService.response.body.id}}/reject
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "reason": "Incomplete details"
}

###
# @name bulkApproveServices
PATCH {{baseUrl}}/api/v1/services/bulk-approve
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "ids": [1, 2, 3],
  "reason": "Bulk approval - all services meet quality standards"
}

###
# @name bulkRejectServices
PATCH {{baseUrl}}/api/v1/services/bulk-reject
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "ids": [4, 5, 6],
  "reason": "Bulk rejection - services do not meet requirements"
}

###
# @name bulkSuspendServices
PATCH {{baseUrl}}/api/v1/services/bulk-suspend
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "ids": [7, 8, 9],
  "reason": "Bulk suspension - temporary pause for review"
}

###
# @name suspendService
PATCH {{baseUrl}}/api/v1/services/{{createService.response.body.id}}/suspend
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "reason": "Temporary suspension"
}

###
# @name featuredServices
GET {{baseUrl}}/api/v1/services/featured?limit=5
Authorization: Bearer {{login.response.body.token}}

###
# @name popularServices
GET {{baseUrl}}/api/v1/services/popular?limit=5
Authorization: Bearer {{login.response.body.token}}

###
# @name nearbyServices
GET {{baseUrl}}/api/v1/services/nearby?latitude=14.5995&longitude=120.9842&radius_km=25&limit=5
Authorization: Bearer {{login.response.body.token}}

###
# @name searchServices
GET {{baseUrl}}/api/v1/services/search?q=clean&category_ids={{createServiceCategory.response.body.id}}&min_price=100&max_price=5000&sort_by=rating&limit=10
Authorization: Bearer {{login.response.body.token}}

###
# @name suggestionsServices
GET {{baseUrl}}/api/v1/services/search/suggestions?q=clean&limit=5
Authorization: Bearer {{login.response.body.token}}

###
# @name popularSearchTerms
# Get popular search terms (TRV-006)
GET {{baseUrl}}/api/v1/services/search/popular?limit=10
Authorization: Bearer {{login.response.body.token}}

###
# @name detailService
GET {{baseUrl}}/api/v1/services/{{createService.response.body.id}}/detail
Authorization: Bearer {{login.response.body.token}}

###
# @name scheduleByCourt
GET {{baseUrl}}/api/v1/services/schedule-by-court?service_id={{createService.response.body.id}}
Authorization: Bearer {{login.response.body.token}}

###
# @name scheduleByCourtFiltered
GET {{baseUrl}}/api/v1/services/schedule-by-court?service_id={{createService.response.body.id}}&date=2026-03-05
Authorization: Bearer {{login.response.body.token}}

###
# @name bulkDeleteServices
DELETE {{baseUrl}}/api/v1/services/bulk-delete
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "ids": [10, 11, 12],
  "reason": "Bulk deletion - services no longer needed"
}
