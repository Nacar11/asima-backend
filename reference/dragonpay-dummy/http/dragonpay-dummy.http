### DragonPay Dummy API - Test Endpoints
### Base URL: http://localhost:4080/api/v1/dragonpay-dummy

# ============================================================================
# Variables
# ============================================================================
@baseUrl = http://localhost:4080/api/v1/dragonpay-dummy
@txnid = TXN-{{$timestamp}}-TEST


# ============================================================================
# Payment Creation (Section 5.2)
# ============================================================================

### Create a new payment request
# @name createPayment
POST {{baseUrl}}/collect
Content-Type: application/json

{
  "txnid": "{{txnid}}",
  "amount": 1500.00,
  "ccy": "PHP",
  "description": "Test payment for booking #123",
  "email": "customer@example.com",
  "firstName": "Juan",
  "lastName": "Dela Cruz",
  "procId": "GCSH",
  "postbackUrl": "{{baseUrl}}/postback",
  "returnUrl": "http://localhost:3000/payment/success",
  "cancelUrl": "http://localhost:3000/payment/cancel",
  "param1": "{\"booking_id\": 123}"
}


### Create payment with minimal fields
POST {{baseUrl}}/collect
Content-Type: application/json

{
  "txnid": "TXN-MINIMAL-{{$timestamp}}",
  "amount": 500.00,
  "ccy": "PHP",
  "description": "Minimal test payment",
  "email": "test@example.com"
}


# ============================================================================
# Transaction Status (Section 5.3)
# ============================================================================

### Get transaction status
# Replace TXN-ID with actual transaction ID from createPayment response
GET {{baseUrl}}/collect/TXN-1735776000-TEST
Content-Type: application/json


### Cancel a transaction
DELETE {{baseUrl}}/collect/TXN-1735776000-TEST
Content-Type: application/json


# ============================================================================
# Available Processors (Section 7.2.2)
# ============================================================================

### Get all available processors for 1000 PHP
GET {{baseUrl}}/processors?amount=1000&ccy=PHP

### Get online processors only
GET {{baseUrl}}/processors?amount=1000&ccy=PHP&mode=online

### Get offline (OTC) processors only
GET {{baseUrl}}/processors?amount=1000&ccy=PHP&mode=offline

### Get processors for high amount (should filter out some)
GET {{baseUrl}}/processors?amount=100000&ccy=PHP


# ============================================================================
# Payment Simulation (For Testing)
# ============================================================================

### Simulate successful payment
# Replace TXN-ID with actual transaction ID
POST {{baseUrl}}/simulate
Content-Type: application/json

{
  "txnid": "TXN-1735776000-TEST",
  "status": "S",
  "message": "Payment completed successfully"
}


### Simulate failed payment
POST {{baseUrl}}/simulate
Content-Type: application/json

{
  "txnid": "TXN-1735776000-TEST",
  "status": "F",
  "message": "Payment failed - insufficient funds"
}


### Simulate with delay (2 seconds before postback)
POST {{baseUrl}}/simulate
Content-Type: application/json

{
  "txnid": "TXN-1735776000-TEST",
  "status": "S",
  "delay": 2000
}


# ============================================================================
# Postback/Webhook Testing
# ============================================================================

### Send test postback (simulates DragonPay callback)
POST {{baseUrl}}/postback
Content-Type: application/json

{
  "txnid": "TXN-1735776000-TEST",
  "refno": "DPREF-20260102-ABC123",
  "status": "S",
  "message": "Transaction successful",
  "amount": 1500.00,
  "ccy": "PHP"
}


# ============================================================================
# Debugging Endpoints
# ============================================================================

### List all stored transactions
GET {{baseUrl}}/transactions


### Clear all transactions
DELETE {{baseUrl}}/transactions


# ============================================================================
# Payment Page Flow (Browser Testing)
# ============================================================================

### Get payment page
# Open this URL in browser to see the dummy payment page
# GET {{baseUrl}}/pay?txnid=TXN-123&refno=DPREF-123

### Completion page
# GET {{baseUrl}}/complete?txnid=TXN-123&status=S


# ============================================================================
# Full Test Flow Example
# ============================================================================

### Step 1: Create payment
# @name step1
POST {{baseUrl}}/collect
Content-Type: application/json

{
  "txnid": "FLOW-{{$timestamp}}",
  "amount": 2500.00,
  "ccy": "PHP",
  "description": "Full flow test",
  "email": "flow@example.com",
  "postbackUrl": "{{baseUrl}}/postback"
}

### Step 2: Check status (should be Pending)
# Use txnid from step 1
GET {{baseUrl}}/collect/FLOW-{{$timestamp}}

### Step 3: Simulate successful payment
POST {{baseUrl}}/simulate
Content-Type: application/json

{
  "txnid": "FLOW-{{$timestamp}}",
  "status": "S"
}

### Step 4: Verify status (should be Success)
GET {{baseUrl}}/collect/FLOW-{{$timestamp}}

