@baseUrl = http://localhost:4080
@token = your_token_here

### Login
# @name Login
POST {{baseUrl}}/api/v1/auth/email/login
Content-Type: application/json

{
  "email": "admin@cody.inc",
  "password": "password"
}

### Get Token
@token = {{Login.response.body.token}}

### Create Seller Payout Account (Bank)
# @name CreateBankAccount
POST {{baseUrl}}/api/v1/seller-payout-accounts
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "seller_id": 1,
  "account_type": "bank_transfer",
  "account_name": "John Doe",
  "account_number": "1234567890",
  "bank_name": "Bank of the Philippines",
  "bank_code": "BOP",
  "bank_branch": "Makati Branch",
  "swift_code": "BOPHPHMM",
  "is_default": true,
  "status": "active"
}

### Create Seller Payout Account (GCash)
# @name CreateGCashAccount
POST {{baseUrl}}/api/v1/seller-payout-accounts
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "seller_id": 1,
  "account_type": "gcash",
  "account_name": "John Doe",
  "account_number": "09123456789",
  "mobile_number": "+639123456789",
  "is_default": false,
  "status": "active"
}

### Get All Seller Payout Accounts
GET {{baseUrl}}/api/v1/seller-payout-accounts?page=1&limit=10
Authorization: Bearer {{token}}

### Get Seller Payout Accounts by Seller ID
GET {{baseUrl}}/api/v1/seller-payout-accounts/seller/1
Authorization: Bearer {{token}}

### Get Default Payout Account
GET {{baseUrl}}/api/v1/seller-payout-accounts/seller/1/default
Authorization: Bearer {{token}}

### Get Seller Payout Account by ID
GET {{baseUrl}}/api/v1/seller-payout-accounts/{{CreateBankAccount.response.body.id}}
Authorization: Bearer {{token}}

### Update Seller Payout Account
PATCH {{baseUrl}}/api/v1/seller-payout-accounts/{{CreateBankAccount.response.body.id}}
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "is_verified": true,
  "verified_at": "2024-12-12T00:00:00Z"
}



