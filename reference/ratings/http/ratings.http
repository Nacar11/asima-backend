### Variables
@baseUrl = http://localhost:4080
@adminEmail = admin@cody.inc
@adminPassword = password

### Get Auth Token
# @name login
POST {{baseUrl}}/api/v1/auth/email/login
accept: application/json
Content-Type: application/json

{
  "email": "{{adminEmail}}",
  "password": "{{adminPassword}}"
}

###
### ===========================================
### RATINGS ENDPOINTS
### ===========================================

### Submit a Rating for a Booking
# @name submitRating
POST {{baseUrl}}/api/v1/ratings
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "booking_id": 1,
  "review_comment": "Excellent service! The team was very professional and completed the work ahead of schedule.",
  "is_public": true,
  "items": [
    {
      "rating_template_id": 1,
      "value": 5
    },
    {
      "rating_template_id": 2,
      "value": 4
    }
  ]
}

### List Ratings by Seller
# @name listBySellerRatings
GET {{baseUrl}}/api/v1/ratings?seller_id=1&page=1&limit=10
Authorization: Bearer {{login.response.body.token}}

### List Ratings by Service
# @name listByServiceRatings
GET {{baseUrl}}/api/v1/ratings?service_id=1&page=1&limit=10
Authorization: Bearer {{login.response.body.token}}

### Get My Ratings (Customer)
# @name getMyRatings
GET {{baseUrl}}/api/v1/ratings/my-ratings?page=1&limit=10
Authorization: Bearer {{login.response.body.token}}

### Get Rating by Booking ID
# @name getRatingByBooking
GET {{baseUrl}}/api/v1/ratings/booking/1
Authorization: Bearer {{login.response.body.token}}

### Get Rating by ID
# @name getRatingById
GET {{baseUrl}}/api/v1/ratings/1
Authorization: Bearer {{login.response.body.token}}

### Get Seller Average Rating
# @name getSellerAverage
GET {{baseUrl}}/api/v1/ratings/seller/1/average
Authorization: Bearer {{login.response.body.token}}

### Get Service Average Rating
# @name getServiceAverage
GET {{baseUrl}}/api/v1/ratings/service/1/average
Authorization: Bearer {{login.response.body.token}}

### Update Rating (Customer updates comment/visibility)
# @name updateRating
PATCH {{baseUrl}}/api/v1/ratings/1
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "review_comment": "Updated: Excellent service! Highly recommended.",
  "is_public": true
}

### Add Seller Response
# @name addSellerResponse
PATCH {{baseUrl}}/api/v1/ratings/1/seller-response
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "seller_response": "Thank you for your kind feedback! We're glad you were satisfied with our service."
}

### Delete Rating (Soft Delete)
# @name deleteRating
DELETE {{baseUrl}}/api/v1/ratings/1
Authorization: Bearer {{login.response.body.token}}

###
### ===========================================
### ERROR SCENARIOS
### ===========================================

### Error: Rating Not Found
# @name errorNotFound
GET {{baseUrl}}/api/v1/ratings/999999
Authorization: Bearer {{login.response.body.token}}

### Error: Unauthorized (No Token)
# @name errorUnauthorized
GET {{baseUrl}}/api/v1/ratings/1

### Error: Booking Not Found
# @name errorBookingNotFound
POST {{baseUrl}}/api/v1/ratings
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "booking_id": 999999,
  "items": [
    {"rating_template_id": 1, "value": 5}
  ]
}

### Error: Invalid Rating Value (Out of Range)
# @name errorInvalidValue
POST {{baseUrl}}/api/v1/ratings
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "booking_id": 1,
  "items": [
    {"rating_template_id": 1, "value": 10}
  ]
}
