# @name login
POST {{baseUrl}}/api/v1/auth/email/login
accept: application/json
Content-Type: application/json

{
  "email": "{{adminEmail}}",
  "password": "{{adminPassword}}"
}

###
# @name createServiceCategory
POST {{baseUrl}}/api/v1/service-categories
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "name": "Gallery Cat {{timestamp}}",
  "slug": "gallery-cat-{{timestamp}}",
  "description": "Category for gallery tests"
}

###
# @name createService
POST {{baseUrl}}/api/v1/services
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "seller_id": 1,
  "category_id": "{{createServiceCategory.response.body.id}}",
  "title": "Gallery Service {{timestamp}}",
  "slug": "gallery-service-{{timestamp}}",
  "pricing_type": "fixed",
  "base_price": 900,
  "estimated_duration_minutes": 60,
  "service_radius_km": 10,
  "is_remote_available": false,
  "max_bookings_per_day": 5,
  "advance_booking_days": 30,
  "minimum_notice_hours": 12,
  "status": "draft",
  "is_featured": false,
  "requires_quote": false,
  "instant_booking": true
}

###
# @name createGallery
POST {{baseUrl}}/api/v1/service-gallery
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "service_id": "{{createService.response.body.id}}",
  "image_url": "https://example.com/gallery-{{timestamp}}.jpg",
  "caption": "Before cleaning",
  "alt_text": "Before cleaning image",
  "is_primary": true,
  "display_order": 1
}

###
# @name createGallery2
POST {{baseUrl}}/api/v1/service-gallery
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "service_id": "{{createService.response.body.id}}",
  "image_url": "https://example.com/gallery-{{timestamp}}-after.jpg",
  "caption": "After cleaning",
  "alt_text": "After cleaning image",
  "is_primary": false,
  "display_order": 2
}

###
# @name listGallery
GET {{baseUrl}}/api/v1/service-gallery?take=10&skip=0
Authorization: Bearer {{login.response.body.token}}

###
# @name getGallery
GET {{baseUrl}}/api/v1/service-gallery/{{createGallery.response.body.id}}
Authorization: Bearer {{login.response.body.token}}

###
# @name updateGallery
PATCH {{baseUrl}}/api/v1/service-gallery/{{createGallery2.response.body.id}}
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "is_primary": true,
  "display_order": 1
}

###
# @name deleteGallery
DELETE {{baseUrl}}/api/v1/service-gallery/{{createGallery.response.body.id}}
Authorization: Bearer {{login.response.body.token}}




