# --- App ---
NODE_ENV=development
APP_NAME=asima
APP_PORT=3000
API_PREFIX=api
FRONTEND_DOMAIN=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Database ---
DATABASE_TYPE=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=asima
DATABASE_PASSWORD=asima
DATABASE_NAME=asima
DATABASE_SYNCHRONIZE=false
DATABASE_MAX_CONNECTIONS=20
DATABASE_SSL_ENABLED=false

# --- Auth (JWT) ---
AUTH_JWT_SECRET=change-me-access-secret
AUTH_JWT_TOKEN_EXPIRES_IN=15m
AUTH_REFRESH_SECRET=change-me-refresh-secret
AUTH_REFRESH_TOKEN_EXPIRES_IN=7d

# --- Object storage (S3 API: MinIO locally, AWS S3 in deployed envs) ---
# One adapter, switched only by these vars — never an `if (env)` in code.
# LOCAL (MinIO): host-mode dev uses http://localhost:9000 (the published
# port of the asima-minio container).
# DEPLOYED (AWS S3): leave STORAGE_ENDPOINT empty, set the real region +
# IAM creds, and STORAGE_FORCE_PATH_STYLE=false.
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_BUCKET=asima
STORAGE_ACCESS_KEY=asima-minio
STORAGE_SECRET_KEY=asima-minio-secret
STORAGE_FORCE_PATH_STYLE=true
STORAGE_MAX_FILE_MB=10

# MinIO root credentials (local container only). Mirror STORAGE_ACCESS_KEY /
# STORAGE_SECRET_KEY so the API and the bucket-init job share one identity.
MINIO_ROOT_USER=asima-minio
MINIO_ROOT_PASSWORD=asima-minio-secret

# --- Seed (used by `npm run seed`) ---
# Single password applied to ALL seeded users (admin, HR, PMs, TDs, employees).
# Existing users on re-seed are NOT touched — change here only affects new rows.
SEED_DEFAULT_PASSWORD=Asima@1234
