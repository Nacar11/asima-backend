# --- App ---
NODE_ENV=development
APP_NAME=asima
APP_PORT=3000
API_PREFIX=api
FRONTEND_DOMAIN=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Database ---
DATABASE_TYPE=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=asima
DATABASE_PASSWORD=asima
DATABASE_NAME=asima
DATABASE_SYNCHRONIZE=false
DATABASE_MAX_CONNECTIONS=20
DATABASE_SSL_ENABLED=false

# --- Auth (JWT) ---
AUTH_JWT_SECRET=change-me-access-secret
AUTH_JWT_TOKEN_EXPIRES_IN=15m
AUTH_REFRESH_SECRET=change-me-refresh-secret
AUTH_REFRESH_TOKEN_EXPIRES_IN=7d

# --- Seed (used by `npm run seed` and SEED_ON_BOOT=true in Docker) ---
SEED_ADMIN_EMAIL=admin@asima.local
SEED_ADMIN_PASSWORD=Admin@1234
SEED_ON_BOOT=false
